@using SporthalleWeb.Application.PassiveMembership
@using SporthalleWeb.Domain.PassiveMembership
@inject AdminService AdminService

<div class="p-3">

@if (!string.IsNullOrEmpty(_message))
{
  <div class="alert @(_isError ? "alert-danger" : "alert-success") py-2 px-3 mb-3" role="alert">@_message</div>
}

@if (_loading)
{
  <p class="text-muted">Lade Mitglieder…</p>
}
else if (_members.Count == 0)
{
  <p class="text-muted">Noch keine bestätigten Passivmitglieder.</p>
}
else
{
  <p class="text-muted mb-2" style="font-size:0.875rem;">@_members.Count Mitglied@(_members.Count == 1 ? "" : "er")</p>
  <div class="table-responsive">
    <table class="table table-hover align-middle" style="font-size:0.875rem;">
      <thead>
        <tr>
          <th style="cursor:pointer" @onclick='() => Sort("FieldNumber")'>Feld @Ind("FieldNumber")</th>
          <th>VIP</th>
          <th style="cursor:pointer" @onclick='() => Sort("LevelKey")'>Stufe @Ind("LevelKey")</th>
          <th style="cursor:pointer" @onclick='() => Sort("LastName")'>Name @Ind("LastName")</th>
          <th>E-Mail</th>
          <th>Adresse</th>
          <th style="cursor:pointer" @onclick='() => Sort("CreatedAt")'>Angemeldet @Ind("CreatedAt")</th>
          <th>Zahlung 1. Rate</th>
          <th>In FiBu übertragen</th>
          <th>Notizen</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var m in Sorted())
        {
          var id = m.Id;
          <tr class="@(m.PaidAt.HasValue ? "table-success" : "")">
            <td class="fw-semibold">@m.FieldNumber.Value</td>
            <td><span class="text-muted">@(VipField.GetLabel(m.FieldNumber.Value) ?? "")</span></td>
            <td>
              <span class="badge" style="@LevelBadgeStyle(m.Level.Key)">@m.Level.Key</span>
            </td>
            <td class="text-nowrap">@m.FirstName @m.LastName</td>
            <td><a href="mailto:@m.Email.Value" class="text-decoration-none">@m.Email.Value</a></td>
            <td class="text-muted" style="font-size:0.8rem;">
              @m.AddressLine
              @if (!string.IsNullOrEmpty(m.AddressLine2)) { <br /><span>@m.AddressLine2</span> }
              <br />@m.PostalCode @m.City
              @if (!string.IsNullOrEmpty(m.Phone)) { <br /><span>Tel. @m.Phone</span> }
            </td>
            <td class="text-nowrap" style="font-size:0.8rem;">
              @m.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")<br />
              <span class="text-muted">@m.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
            </td>
            <td class="text-nowrap">
              @if (m.PaidAt.HasValue)
              {
                <div class="text-success fw-semibold" style="font-size:0.8rem;">
                  ✓ @m.PaidAt.Value.ToLocalTime().ToString("dd.MM.yyyy")
                </div>
                @if (!string.IsNullOrEmpty(m.PaidBy))
                {
                  <div class="text-muted" style="font-size:0.75rem;">@m.PaidBy</div>
                }
                <button class="btn btn-sm btn-outline-secondary mt-1" style="font-size:0.75rem;"
                        disabled="@_busy.Contains(id)"
                        @onclick='() => _confirm!.Show(
                            "1. Rate zurücksetzen",
                            "Zahlung wirklich zurücksetzen?",
                            "Ja, zurücksetzen", "btn-danger",
                            () => MarkUnpaid(id))'>
                  Zurücksetzen
                </button>
              }
              else
              {
                <button class="btn btn-sm btn-success" disabled="@_busy.Contains(id)"
                        @onclick='() => _confirm!.Show(
                            "1. Rate bestätigen",
                            "Zahlung als bezahlt markieren?",
                            "Ja, markieren", "btn-success",
                            () => MarkPaid(id))'>
                  Als bezahlt markieren
                </button>
              }
            </td>
            <td class="text-nowrap">
              @if (m.ExportedToAccountingAt.HasValue)
              {
                <div class="text-success fw-semibold" style="font-size:0.8rem;">
                  ✓ @m.ExportedToAccountingAt.Value.ToLocalTime().ToString("dd.MM.yyyy")
                </div>
                @if (!string.IsNullOrEmpty(m.ExportedToAccountingBy))
                {
                  <div class="text-muted" style="font-size:0.75rem;">@m.ExportedToAccountingBy</div>
                }
                <button class="btn btn-sm btn-outline-secondary mt-1" style="font-size:0.75rem;"
                        disabled="@_busy.Contains(id)"
                        @onclick='() => _confirm!.Show(
                            "FiBu-Eintrag zurücksetzen",
                            "FiBu-Eintrag wirklich zurücksetzen?",
                            "Ja, zurücksetzen", "btn-danger",
                            () => UnmarkAccounting(id))'>
                  Zurücksetzen
                </button>
              }
              else
              {
                <button class="btn btn-sm btn-success" disabled="@_busy.Contains(id)"
                        @onclick='() => _confirm!.Show(
                            "In FiBu übertragen",
                            "Als in FiBu eingetragen markieren?",
                            "Ja, markieren", "btn-success",
                            () => MarkAccounting(id))'>
                  Als eingetragen markieren
                </button>
              }
            </td>
            <td>
              <textarea class="form-control form-control-sm" rows="2" style="min-width:130px;font-size:0.8rem;"
                        @bind="_notes[id]"
                        @bind:event="oninput"
                        @onblur="() => SaveNotes(id)">
              </textarea>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

</div>

<ConfirmDialogComponent @ref="_confirm" />

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    private ConfirmDialogComponent? _confirm;
    private IReadOnlyList<PassiveMember> _members = [];
    private Dictionary<int, string?> _notes = [];
    private HashSet<int> _busy = [];
    private bool _loading = true;
    private string? _message;
    private bool _isError;
    private string _sortCol = "FieldNumber";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _members = await AdminService.GetConfirmedAsync();
        _notes = _members.ToDictionary(m => m.Id, m => m.Notes);
        _loading = false;
    }

    private async Task MarkPaid(int id)
    {
        _busy.Add(id);
        try
        {
            await AdminService.MarkAsPaidAsync(id, AdminUser);
            await LoadAsync();
            ShowMsg("Zahlung gespeichert.", false);
        }
        catch (Exception ex) { ShowMsg($"Fehler: {ex.Message}", true); }
        finally { _busy.Remove(id); }
    }

    private async Task MarkUnpaid(int id)
    {
        _busy.Add(id);
        try
        {
            await AdminService.MarkAsUnpaidAsync(id);
            await LoadAsync();
            ShowMsg("Zahlung zurückgesetzt.", false);
        }
        catch (Exception ex) { ShowMsg($"Fehler: {ex.Message}", true); }
        finally { _busy.Remove(id); }
    }

    private async Task MarkAccounting(int id)
    {
        _busy.Add(id);
        try
        {
            await AdminService.MarkAsExportedToAccountingAsync(id, AdminUser);
            await LoadAsync();
            ShowMsg("Als FiBu-eingetragen markiert.", false);
        }
        catch (Exception ex) { ShowMsg($"Fehler: {ex.Message}", true); }
        finally { _busy.Remove(id); }
    }

    private async Task UnmarkAccounting(int id)
    {
        _busy.Add(id);
        try
        {
            await AdminService.UnmarkAsExportedToAccountingAsync(id);
            await LoadAsync();
            ShowMsg("FiBu-Eintrag zurückgesetzt.", false);
        }
        catch (Exception ex) { ShowMsg($"Fehler: {ex.Message}", true); }
        finally { _busy.Remove(id); }
    }

    private async Task SaveNotes(int id)
    {
        try
        {
            await AdminService.UpdateNotesAsync(id, _notes.GetValueOrDefault(id));
            ShowMsg("Notiz gespeichert.", false);
        }
        catch (Exception ex) { ShowMsg($"Fehler: {ex.Message}", true); }
    }

    private void Sort(string col)
    {
        _sortAsc = _sortCol == col ? !_sortAsc : true;
        _sortCol = col;
    }

    private IEnumerable<PassiveMember> Sorted() =>
        _sortCol switch
        {
            "LevelKey"  => _sortAsc ? _members.OrderBy(m => m.Level.Key)         : _members.OrderByDescending(m => m.Level.Key),
            "LastName"  => _sortAsc ? _members.OrderBy(m => m.LastName)          : _members.OrderByDescending(m => m.LastName),
            "CreatedAt" => _sortAsc ? _members.OrderBy(m => m.CreatedAt)         : _members.OrderByDescending(m => m.CreatedAt),
            _           => _sortAsc ? _members.OrderBy(m => m.FieldNumber.Value) : _members.OrderByDescending(m => m.FieldNumber.Value),
        };

    private string Ind(string col) => _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";

    private static string LevelBadgeStyle(string key) => key.ToLower() switch
    {
        "gold"   => "background:#b08000;color:#fff",
        "silber" => "background:#909090;color:#fff",
        _        => "background:#cd7f32;color:#fff",
    };

    private void ShowMsg(string msg, bool isError)
    {
        _message = msg;
        _isError = isError;
        _ = Task.Delay(3000).ContinueWith(_ => { _message = null; InvokeAsync(StateHasChanged); });
    }
}
