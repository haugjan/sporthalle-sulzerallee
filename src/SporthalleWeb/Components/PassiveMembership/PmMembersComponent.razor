@using SporthalleWeb.Application.PassiveMembership
@using SporthalleWeb.Domain.PassiveMembership
@inject AdminService AdminService

<style>
  * { box-sizing: border-box; }
  body { font-family: sans-serif; font-size: 14px; color: #1a1a2e; background: #f5f6fa; margin: 0; }
  .toolbar { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.5rem 0; }
  .count { color: #666; font-size: 0.9rem; }
  .msg { padding: 0.5rem 1rem; border-radius: 5px; font-size: 0.85rem; font-weight: 600; margin: 0.5rem 1.5rem; }
  .msg-ok  { background: #d1fae5; color: #065f46; }
  .msg-err { background: #fee2e2; color: #991b1b; }
  .table-wrap { overflow-x: auto; margin: 1rem 1.5rem; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  table { width: 100%; border-collapse: collapse; background: #fff; font-size: 0.83rem; }
  th { background: #1A5FAD; color: #fff; padding: 0.65rem 0.75rem; text-align: left; white-space: nowrap; cursor: pointer; user-select: none; }
  th:hover { background: #1550a0; }
  td { padding: 0.55rem 0.75rem; border-bottom: 1px solid #eef0f5; vertical-align: top; }
  tr:last-child td { border-bottom: none; }
  tr.paid td { background: #f0f9f0; }
  .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 3px; font-size: 0.75rem; font-weight: 700; }
  .badge-bronze { background: #cd7f32; color: #fff; }
  .badge-silber { background: #909090; color: #fff; }
  .badge-gold   { background: #b08000; color: #fff; }
  .paid-mark { color: #2d8a4e; font-weight: 600; }
  .btn-pay { background: #1A5FAD; color: #fff; border: none; border-radius: 4px; padding: 0.3rem 0.65rem; font-size: 0.78rem; cursor: pointer; }
  .btn-pay:hover { background: #1550a0; }
  .btn-pay:disabled { opacity: 0.4; cursor: default; }
  textarea.notes { width: 100%; min-width: 140px; border: 1px solid #dde1ec; border-radius: 4px; padding: 0.3rem; font-family: inherit; font-size: 0.82rem; resize: vertical; }
  textarea.notes:focus { outline: 2px solid #1A5FAD; border-color: transparent; }
</style>

<div class="toolbar">
  @if (_members.Count > 0)
  {
    <span class="count">@_members.Count Mitglied@(_members.Count == 1 ? "" : "er")</span>
  }
</div>

@if (!string.IsNullOrEmpty(_message))
{
  <div class="msg @(_isError ? "msg-err" : "msg-ok")">@_message</div>
}

@if (_loading)
{
  <p style="padding:1.5rem;color:#888;">Lade Mitglieder…</p>
}
else if (_members.Count == 0)
{
  <p style="padding:1.5rem;color:#888;">Noch keine Passivmitglieder registriert.</p>
}
else
{
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th @onclick='() => Sort("FieldNumber")'>Feld @Ind("FieldNumber")</th>
          <th>VIP</th>
          <th @onclick='() => Sort("LevelKey")'>Stufe @Ind("LevelKey")</th>
          <th @onclick='() => Sort("LastName")'>Name @Ind("LastName")</th>
          <th>E-Mail</th>
          <th>Adresse</th>
          <th @onclick='() => Sort("CreatedAt")'>Angemeldet @Ind("CreatedAt")</th>
          <th>Bezahlt</th>
          <th>Notizen</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var m in Sorted())
        {
          var id = m.Id;
          <tr class="@(m.PaidAt.HasValue ? "paid" : "")">
            <td>@m.FieldNumber.Value</td>
            <td>@(VipField.GetLabel(m.FieldNumber.Value) ?? "")</td>
            <td><span class="badge badge-@m.Level.Key.ToLower()">@m.Level.Key</span></td>
            <td>@m.FirstName @m.LastName</td>
            <td><a href="mailto:@m.Email.Value">@m.Email.Value</a></td>
            <td>@m.AddressLine<br />@m.PostalCode @m.City</td>
            <td>
              @m.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")<br />
              <span style="color:#888;font-size:0.78rem;">@m.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
            </td>
            <td>
              @if (m.PaidAt.HasValue)
              {
                <span class="paid-mark">✓ @m.PaidAt.Value.ToLocalTime().ToString("dd.MM.yyyy")</span>
              }
              else
              {
                <button class="btn-pay" disabled="@_busy.Contains(id)" @onclick="() => MarkPaid(id)">
                  Als bezahlt markieren
                </button>
              }
            </td>
            <td>
              <textarea class="notes" rows="2"
                        @bind="_notes[id]"
                        @bind:event="oninput"
                        @onblur="() => SaveNotes(id)">
              </textarea>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@code {
    private IReadOnlyList<PassiveMember> _members = [];
    private Dictionary<int, string?> _notes = [];
    private HashSet<int> _busy = [];
    private bool _loading = true;
    private string? _message;
    private bool _isError;
    private string _sortCol = "FieldNumber";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _members = await AdminService.GetAllAsync();
        _notes = _members.ToDictionary(m => m.Id, m => m.Notes);
        _loading = false;
    }

    private async Task MarkPaid(int id)
    {
        _busy.Add(id);
        try
        {
            await AdminService.MarkAsPaidAsync(id);
            await LoadAsync();
            ShowMsg("Zahlung gespeichert.", false);
        }
        catch (Exception ex)
        {
            ShowMsg($"Fehler: {ex.Message}", true);
        }
        finally
        {
            _busy.Remove(id);
        }
    }

    private async Task SaveNotes(int id)
    {
        try
        {
            await AdminService.UpdateNotesAsync(id, _notes.GetValueOrDefault(id));
            ShowMsg("Notiz gespeichert.", false);
        }
        catch (Exception ex)
        {
            ShowMsg($"Fehler: {ex.Message}", true);
        }
    }

    private void Sort(string col)
    {
        _sortAsc = _sortCol == col ? !_sortAsc : true;
        _sortCol = col;
    }

    private IEnumerable<PassiveMember> Sorted() =>
        (_sortCol switch
        {
            "LevelKey"  => _sortAsc ? _members.OrderBy(m => m.Level.Key)           : _members.OrderByDescending(m => m.Level.Key),
            "LastName"  => _sortAsc ? _members.OrderBy(m => m.LastName)            : _members.OrderByDescending(m => m.LastName),
            "CreatedAt" => _sortAsc ? _members.OrderBy(m => m.CreatedAt)           : _members.OrderByDescending(m => m.CreatedAt),
            _           => _sortAsc ? _members.OrderBy(m => m.FieldNumber.Value)   : _members.OrderByDescending(m => m.FieldNumber.Value),
        });

    private string Ind(string col) =>
        _sortCol == col ? (_sortAsc ? "▲" : "▼") : "";

    private void ShowMsg(string msg, bool isError)
    {
        _message = msg;
        _isError = isError;
        _ = Task.Delay(3000).ContinueWith(_ => { _message = null; InvokeAsync(StateHasChanged); });
    }
}
