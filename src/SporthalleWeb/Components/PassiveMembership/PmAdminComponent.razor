<style>
  html, body { margin: 0; height: 100%; }
  * { box-sizing: border-box; }
  .pm-admin { display: flex; flex-direction: column; height: 100vh; font-family: sans-serif; font-size: 14px; color: #1a1a2e; background: #f5f6fa; }
  .subnav { background: #1A5FAD; display: flex; align-items: stretch; padding: 0 0.5rem; flex-shrink: 0; }
  .subnav-btn { color: rgba(255,255,255,0.75); background: none; border: none;
    border-bottom: 3px solid transparent; padding: 0.7rem 1.25rem;
    font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit;
    display: flex; align-items: center; gap: 0.4rem; }
  .subnav-btn:hover { color: #fff; background: rgba(255,255,255,0.1); }
  .subnav-btn.active { color: #fff; border-bottom-color: #fff; }
  .tab-content { flex: 1; overflow-y: auto; }
  .pending-badge { background: #ff5252; color: #fff; border-radius: 10px;
    font-size: 0.72rem; font-weight: 700; padding: 0.1rem 0.45rem; line-height: 1.4; }
</style>

<div class="pm-admin">
  <nav class="subnav">
    <button class="subnav-btn @(_tab == "anfragen" ? "active" : "")"
            @onclick='() => _tab = "anfragen"'>
      Anfragen
      @if (_pendingCount > 0)
      {
        <span class="pending-badge">@_pendingCount</span>
      }
    </button>
    <button class="subnav-btn @(_tab == "mitglieder" ? "active" : "")"
            @onclick='() => _tab = "mitglieder"'>Mitglieder</button>
    <button class="subnav-btn @(_tab == "exporte" ? "active" : "")"
            @onclick='() => _tab = "exporte"'>Exporte</button>
  </nav>
  <div class="tab-content">
    @if (_tab == "anfragen")
    {
      <PmRequestsComponent AdminUser="@AdminUser" OnConfirmed="HandleConfirmed" OnCountChanged="UpdatePendingCount" />
    }
    else if (_tab == "mitglieder")
    {
      <PmMembersComponent AdminUser="@AdminUser" />
    }
    else
    {
      <PmExportsComponent />
    }
  </div>
</div>

@using SporthalleWeb.Application.PassiveMembership
@inject AdminService AdminService

@code {
    [Parameter] public string AdminUser { get; set; } = "";

    private string _tab = "anfragen";
    private int _pendingCount;

    protected override async Task OnInitializedAsync()
    {
        var pending = await AdminService.GetPendingAsync();
        _pendingCount = pending.Count;
        if (_pendingCount == 0)
            _tab = "mitglieder";
    }

    private void UpdatePendingCount(int count)
    {
        _pendingCount = count;
        StateHasChanged();
    }

    private async Task HandleConfirmed()
    {
        var pending = await AdminService.GetPendingAsync();
        _pendingCount = pending.Count;
        StateHasChanged();
    }
}
