@using System.Globalization

<div class="date-input-nav">

    @if (Value.HasValue)
    {
        <button type="button" class="date-nav-btn" @onclick="PrevDay" aria-label="Vorheriger Tag">&#8249;</button>
        <span class="date-nav-label">@Value.Value.ToString("dd.MM.yyyy", DeCh)</span>
    }
    else if (!Nullable)
    {
        <button type="button" class="date-nav-btn" @onclick="PrevDay" aria-label="Vorheriger Tag">&#8249;</button>
        <span class="date-nav-label">@_today.ToString("dd.MM.yyyy", DeCh)</span>
    }
    else
    {
        <span class="date-nav-empty">Kein Datum</span>
    }

    <button type="button" class="dp-toggle-btn date-nav-dp-btn @(_open ? "dp-active" : "")"
            @onclick="TogglePicker" aria-label="Datum wählen" title="Datum wählen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
    </button>

    @if (Value.HasValue || !Nullable)
    {
        <button type="button" class="date-nav-btn" @onclick="NextDay" aria-label="Nächster Tag">&#8250;</button>
    }

    @if (Nullable && Value.HasValue)
    {
        <button type="button" class="date-nav-clear" @onclick="ClearValue" title="Datum löschen">&#215;</button>
    }

    @if (HiddenInputId is not null)
    {
        <input type="hidden" id="@HiddenInputId"
               value="@(Value.HasValue ? Value.Value.ToString("yyyy-MM-dd") : "")" />
    }

    @if (_open)
    {
        <div style="position:fixed;inset:0;z-index:1090;" @onclick="ClosePicker"></div>
        <div class="dp-popup dp-open din-popup" style="z-index:1100;">
            <div class="dp-nav">
                <button type="button" class="dp-nav-btn" @onclick:stopPropagation @onclick="PrevMonth">&#8249;</button>
                <span class="dp-month-label">@_pickerMonth.ToString("MMMM yyyy", DeCh)</span>
                <button type="button" class="dp-nav-btn" @onclick:stopPropagation @onclick="NextMonth">&#8250;</button>
            </div>
            <div class="dp-weekdays">
                @foreach (var h in Weekdays)
                {
                    <span class="dp-wday">@h</span>
                }
            </div>
            <div class="dp-days">
                @foreach (var d in CalendarDays())
                {
                    if (!d.HasValue)
                    {
                        <span class="dp-day dp-day--empty"></span>
                    }
                    else
                    {
                        var day = d.Value;
                        var isSelected = Value.HasValue && day == Value.Value;
                        var isToday = day == _today;
                        var cls = isSelected ? "dp-day dp-day--bookable dp-day--in-week"
                                : isToday    ? "dp-day dp-day--bookable dp-day--today"
                                :              "dp-day dp-day--bookable";
                        <button type="button" class="@cls"
                                @onclick:stopPropagation
                                @onclick="() => Pick(day)">@day.Day</button>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private static readonly CultureInfo DeCh = CultureInfo.GetCultureInfo("de-CH");
    private static readonly string[] Weekdays = { "Mo", "Di", "Mi", "Do", "Fr", "Sa", "So" };
    private readonly DateOnly _today = DateOnly.FromDateTime(DateTime.Today);

    [Parameter] public DateOnly? Value { get; set; }
    [Parameter] public EventCallback<DateOnly?> ValueChanged { get; set; }
    [Parameter] public bool Nullable { get; set; } = false;
    [Parameter] public string? HiddenInputId { get; set; }

    private bool _open;
    private DateOnly _pickerMonth;

    protected override void OnInitialized()
    {
        var v = Value ?? _today;
        _pickerMonth = new DateOnly(v.Year, v.Month, 1);
    }

    private void TogglePicker()
    {
        _open = !_open;
        if (_open)
        {
            var v = Value ?? _today;
            _pickerMonth = new DateOnly(v.Year, v.Month, 1);
        }
    }

    private void ClosePicker() => _open = false;
    private void PrevMonth() => _pickerMonth = _pickerMonth.AddMonths(-1);
    private void NextMonth() => _pickerMonth = _pickerMonth.AddMonths(1);

    private async Task PrevDay() => await Emit((Value ?? _today).AddDays(-1));
    private async Task NextDay() => await Emit((Value ?? _today).AddDays(1));

    private async Task Pick(DateOnly d)
    {
        _open = false;
        await Emit(d);
    }

    private async Task ClearValue() => await ValueChanged.InvokeAsync(null);

    private async Task Emit(DateOnly d)
    {
        Value = d;
        await ValueChanged.InvokeAsync(d);
    }

    private IEnumerable<DateOnly?> CalendarDays()
    {
        var first = new DateOnly(_pickerMonth.Year, _pickerMonth.Month, 1);
        var offset = ((int)first.DayOfWeek + 6) % 7;
        var count = DateTime.DaysInMonth(_pickerMonth.Year, _pickerMonth.Month);
        for (int i = 0; i < offset; i++) yield return null;
        for (int day = 1; day <= count; day++) yield return new DateOnly(_pickerMonth.Year, _pickerMonth.Month, day);
    }
}
