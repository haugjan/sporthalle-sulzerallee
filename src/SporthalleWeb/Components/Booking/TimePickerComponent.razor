@using System.Globalization

<div class="d-flex align-items-center gap-1">
    <select class="form-select form-select-sm tp-hour" style="width:72px"
            @bind="_hourStr" @bind:after="Emit">
        @for (int h = 0; h < 24; h++)
        {
            <option value="@h.ToString("D2")">@h.ToString("D2")</option>
        }
    </select>
    @if (_minutes.Length > 1)
    {
        <span class="fw-semibold px-1">:</span>
        <select class="form-select form-select-sm tp-minute" style="width:72px"
                @bind="_minuteStr" @bind:after="Emit">
            @foreach (var m in _minutes)
            {
                <option value="@m.ToString("D2")">@m.ToString("D2")</option>
            }
        </select>
    }
    else
    {
        <span class="fw-semibold text-muted">:00</span>
    }
    @if (HiddenInputId is not null)
    {
        <input type="hidden" id="@HiddenInputId" value="@($"{_hourStr}:{_minuteStr}")" />
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "00:00";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public int Step { get; set; } = 60;
    [Parameter] public string? HiddenInputId { get; set; }

    private string _hourStr = "00";
    private string _minuteStr = "00";
    private int[] _minutes = [0];

    protected override void OnParametersSet()
    {
        _minutes = Enumerable.Range(0, 60 / Math.Max(1, Step)).Select(i => i * Step).ToArray();
        if (TimeOnly.TryParse(Value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var t))
        {
            _hourStr = t.Hour.ToString("D2");
            _minuteStr = _minutes.MinBy(m => Math.Abs(m - t.Minute)).ToString("D2");
        }
    }

    private async Task Emit()
    {
        Value = $"{_hourStr}:{_minuteStr}";
        await ValueChanged.InvokeAsync(Value);
    }
}
