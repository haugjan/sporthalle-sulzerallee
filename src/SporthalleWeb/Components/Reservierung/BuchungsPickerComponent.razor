@inject IHttpContextAccessor HttpCtx
@inject SporthalleWeb.Domain.Reservierung.Ports.IHallConfigurationPort Config
@inject SporthalleWeb.Domain.Reservierung.Ports.IMemberManagerPort Members
@inject SporthalleWeb.Application.Reservierung.GetAvailableDaysQuery AvailDays
@inject SporthalleWeb.Application.Reservierung.GetAvailableTimeSlotsQuery AvailSlots
@inject SporthalleWeb.Application.Reservierung.CreateBookingUseCase CreateBooking
@inject SporthalleWeb.Application.Reservierung.SetPasswordUseCase SetPassword
@inject Microsoft.AspNetCore.Components.NavigationManager Nav
@using System.Globalization

<div class="buchungs-picker">

    @if (!string.IsNullOrEmpty(_sessionInfo))
    {
        <div class="alert alert-success mb-3">@_sessionInfo</div>
    }
    @if (!string.IsNullOrEmpty(_sessionError))
    {
        <div class="alert alert-danger mb-3">@_sessionError</div>
    }

    @if (!_isLoggedIn)
    {
        <div class="picker-auth-prompt card p-4 mt-3">
            <h3 class="h5 mb-3">Buchungsanfrage stellen</h3>
            <p>Melde dich an oder registriere dich, um eine Buchungsanfrage zu senden.</p>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/reservierung/anmelden" class="btn btn-primary">Anmelden</a>
                <a href="/reservierung/registrieren" class="btn btn-outline-secondary">Neu registrieren</a>
            </div>
        </div>
    }
    else
    {
        @switch (_step)
        {
            case PickerStep.Dauer:
                <h3 class="h5 mt-3">Buchungsdauer wählen</h3>
                <div class="dauerauswahl d-flex flex-wrap gap-2 mt-2">
                    @foreach (var d in _dauern)
                    {
                        <button class="btn @(_selectedDauer == d ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectDauerAsync(d)">
                            @(d >= 60 ? $"{d / 60} h" : $"{d} min")
                        </button>
                    }
                </div>
                break;

            case PickerStep.Datum:
                <div class="datum-nav d-flex align-items-center gap-3 mt-3">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="PrevMonthAsync">&larr;</button>
                    <strong>@_month.ToString("MMMM yyyy", CultureInfo.GetCultureInfo("de-CH"))</strong>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="NextMonthAsync">&rarr;</button>
                </div>
                @if (_loadingDays)
                {
                    <p class="mt-2">Lade verfügbare Tage…</p>
                }
                else if (!_verfuegbareTage.Any())
                {
                    <p class="mt-2 text-muted">Keine verfügbaren Tage in diesem Monat.</p>
                }
                else
                {
                    <div class="datumauswahl d-flex flex-wrap gap-2 mt-2">
                        @foreach (var tag in _verfuegbareTage)
                        {
                            var tagDate = DateOnly.Parse(tag);
                            <button class="btn btn-sm @(_selectedDate == tag ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SelectDateAsync(tag)">
                                @tagDate.ToString("ddd d. MMM", CultureInfo.GetCultureInfo("de-CH"))
                            </button>
                        }
                    </div>
                }
                <button class="btn btn-secondary mt-3" @onclick="() => _step = PickerStep.Dauer">&larr; Zurück</button>
                break;

            case PickerStep.Zeit:
                <h3 class="h6 mt-3">@_selectedDate — @_selectedDauer min</h3>
                @if (_loadingSlots)
                {
                    <p>Lade freie Zeitfenster…</p>
                }
                else
                {
                    <div class="zeitauswahl d-flex flex-wrap gap-2 mt-2">
                        @foreach (var slot in _slots)
                        {
                            var cls = slot.IsAvailable
                                ? (_selectedSlot == slot ? "btn-primary" : "btn-outline-success")
                                : "btn-outline-secondary";
                            <button class="btn btn-sm @cls"
                                    disabled="@(!slot.IsAvailable)"
                                    @onclick="() => SelectSlot(slot)">
                                @slot.StartLocal – @slot.EndLocal
                                @if (slot.IsAvailable)
                                {
                                    <small class="ms-1">CHF @slot.PriceTotal.ToString("0.–")</small>
                                }
                            </button>
                        }
                    </div>
                }
                <button class="btn btn-secondary mt-3" @onclick="() => _step = PickerStep.Datum">&larr; Zurück</button>
                break;

            case PickerStep.Bestaetigen:
                <h3 class="h5 mt-3">Buchung bestätigen</h3>
                <dl class="row mt-2">
                    <dt class="col-sm-4">Datum / Zeit</dt>
                    <dd class="col-sm-8">@_selectedDate, @_selectedSlot!.StartLocal – @_selectedSlot.EndLocal Uhr</dd>
                    <dt class="col-sm-4">Dauer</dt>
                    <dd class="col-sm-8">@_selectedDauer min</dd>
                    <dt class="col-sm-4">Preis</dt>
                    <dd class="col-sm-8">CHF @_selectedSlot.PriceTotal.ToString("0.–")</dd>
                </dl>
                <div class="mb-3">
                    <label class="form-label">Anlass *</label>
                    <select class="form-select" @bind="_anlass">
                        @foreach (var a in _anlaesse)
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Bemerkungen (optional)</label>
                    <textarea class="form-control" @bind="_notizen" rows="3"></textarea>
                </div>
                @if (_error is not null)
                {
                    <div class="alert alert-danger">@_error</div>
                }
                <p class="text-muted small">Angemeldet als: @_email</p>
                <button class="btn btn-secondary" @onclick="() => _step = PickerStep.Zeit">&larr; Zurück</button>
                <button class="btn btn-primary ms-2" @onclick="SubmitAsync" disabled="@_submitting">
                    @(_submitting ? "Wird gesendet…" : "Buchungsanfrage absenden")
                </button>
                break;

            case PickerStep.Bestaetigung:
                <div class="alert alert-success mt-3">
                    <h4 class="alert-heading">Anfrage eingegangen!</h4>
                    <p class="mb-0">Wir prüfen deinen Termin und melden uns per E-Mail.</p>
                </div>
                @if (!_memberHasPassword)
                {
                    <details class="mt-3">
                        <summary>Passwort für zukünftige Anmeldungen einrichten (optional)</summary>
                        <div class="mt-2 ms-2">
                            <input type="password" class="form-control mb-2" style="max-width:320px"
                                   placeholder="Mindestens 8 Zeichen" @bind="_newPassword" />
                            @if (_passwordMessage is not null)
                            {
                                <p class="@(_passwordError ? "text-danger" : "text-success") small">@_passwordMessage</p>
                            }
                            <button class="btn btn-sm btn-outline-primary" @onclick="SetPasswordAsync">
                                Passwort speichern
                            </button>
                        </div>
                    </details>
                }
                <button class="btn btn-outline-primary mt-3" @onclick="Reset">Weitere Buchung anfragen</button>
                break;
        }
    }
</div>

@code {
    private enum PickerStep { Dauer, Datum, Zeit, Bestaetigen, Bestaetigung }

    private bool _isLoggedIn;
    private int? _memberId;
    private string? _email;
    private bool _memberHasPassword;
    private string? _sessionInfo;
    private string? _sessionError;

    private PickerStep _step = PickerStep.Dauer;
    private IReadOnlyList<int> _dauern = [60, 120];
    private IReadOnlyList<string> _anlaesse = [];
    private int _selectedDauer;
    private DateOnly _month = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<string> _verfuegbareTage = [];
    private bool _loadingDays;
    private string? _selectedDate;
    private IReadOnlyList<SporthalleWeb.Application.Reservierung.SlotOption> _slots = [];
    private bool _loadingSlots;
    private SporthalleWeb.Application.Reservierung.SlotOption? _selectedSlot;
    private string _anlass = "";
    private string? _notizen;
    private string? _error;
    private bool _submitting;

    private string? _newPassword;
    private string? _passwordMessage;
    private bool _passwordError;

    protected override async Task OnInitializedAsync()
    {
        var user = HttpCtx.HttpContext?.User;
        _isLoggedIn = user?.Identity?.IsAuthenticated ?? false;

        if (_isLoggedIn)
        {
            var idStr = user!.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            _memberId = int.TryParse(idStr, out var id) ? id : null;
            _email = user.Identity?.Name;

            _dauern = await Config.GetBuchbareDauernAsync();
            _anlaesse = await Config.GetAnlasseAsync();
            _anlass = _anlaesse.FirstOrDefault() ?? "";

            if (_memberId.HasValue)
            {
                var member = await Members.FindByIdAsync(_memberId.Value);
                _memberHasPassword = member?.HasPassword ?? false;
            }
        }

        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["session"] == "confirmed")
            _sessionInfo = "Du bist jetzt angemeldet!";
        if (query["error"] == "invalid-token")
            _sessionError = "Der Anmelde-Link ist ungültig oder abgelaufen. Bitte fordere einen neuen an.";
    }

    private async Task SelectDauerAsync(int d)
    {
        _selectedDauer = d;
        await LoadDaysAsync();
        _step = PickerStep.Datum;
    }

    private async Task LoadDaysAsync()
    {
        _loadingDays = true;
        _verfuegbareTage = await AvailDays.GetAsync(_month.ToString("yyyy-MM"), _selectedDauer);
        _loadingDays = false;
    }

    private async Task PrevMonthAsync()
    {
        _month = _month.AddMonths(-1);
        await LoadDaysAsync();
    }

    private async Task NextMonthAsync()
    {
        _month = _month.AddMonths(1);
        await LoadDaysAsync();
    }

    private async Task SelectDateAsync(string date)
    {
        _selectedDate = date;
        _step = PickerStep.Zeit;
        _loadingSlots = true;
        _slots = await AvailSlots.GetAsync(date, _selectedDauer);
        _loadingSlots = false;
    }

    private void SelectSlot(SporthalleWeb.Application.Reservierung.SlotOption slot)
    {
        if (!slot.IsAvailable) return;
        _selectedSlot = slot;
        _step = PickerStep.Bestaetigen;
    }

    private async Task SubmitAsync()
    {
        if (_memberId is null) return;
        _submitting = true;
        _error = null;
        try
        {
            var cmd = new SporthalleWeb.Application.Reservierung.CreateBookingCommand(
                _memberId.Value, _selectedSlot!.StartUtc, _selectedSlot.EndUtc, _anlass, _notizen);
            await CreateBooking.ExecuteAsync(cmd);
            _step = PickerStep.Bestaetigung;
        }
        catch (SporthalleWeb.Domain.Reservierung.SlotConflictException)
        {
            _error = "Dieser Zeitslot ist leider nicht mehr verfügbar. Bitte wähle einen anderen Termin.";
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task SetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _memberId is null) return;
        _passwordError = false;
        _passwordMessage = null;
        try
        {
            await SetPassword.ExecuteAsync(_memberId.Value, _newPassword);
            _memberHasPassword = true;
            _passwordMessage = "Passwort gespeichert.";
            _newPassword = null;
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex)
        {
            _passwordError = true;
            _passwordMessage = ex.Message;
        }
    }

    private void Reset()
    {
        _step = PickerStep.Dauer;
        _selectedDauer = 0;
        _selectedDate = null;
        _selectedSlot = null;
        _anlass = _anlaesse.FirstOrDefault() ?? "";
        _notizen = null;
        _error = null;
    }
}
