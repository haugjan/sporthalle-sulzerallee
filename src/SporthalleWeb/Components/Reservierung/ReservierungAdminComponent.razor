@inject SporthalleWeb.Application.Reservierung.BookingAdminService AdminService
@inject SporthalleWeb.Application.Reservierung.ConfirmBookingUseCase ConfirmUseCase
@inject SporthalleWeb.Application.Reservierung.RejectBookingUseCase RejectUseCase
@inject SporthalleWeb.Application.Reservierung.GetWeekSlotsQuery WeekSlotsQuery

<style>
    .reservierung-admin { height: 100%; display: flex; flex-direction: column; }

    .admin-subnav {
        background: #1e4d82;
        display: flex;
        align-items: stretch;
        padding: 0 0.5rem;
        flex-shrink: 0;
    }
    .subnav-btn {
        color: rgba(255, 255, 255, 0.75);
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.7rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: color 0.15s ease, background 0.15s ease;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .subnav-btn:hover {
        color: #fff;
        background: rgba(255, 255, 255, 0.1);
    }
    .subnav-btn.active {
        color: #fff;
        border-bottom-color: #5dade2;
    }

    .admin-content { padding: 1.5rem; flex: 1; overflow-y: auto; }
</style>

<div class="reservierung-admin">

    <nav class="admin-subnav">
        @foreach (var tab in _tabs)
        {
            <button class="subnav-btn @(_activeTab == tab ? "active" : "")"
                    @onclick="() => SetTab(tab)">
                @tab
                @if (tab == "Pendente" && _pending.Count > 0)
                {
                    <span class="badge bg-danger">@_pending.Count</span>
                }
            </button>
        }
    </nav>

    <div class="admin-content">

        @if (_message is not null)
        {
            <div class="alert alert-success alert-dismissible">
                @_message
                <button type="button" class="btn-close" @onclick="() => _message = null"></button>
            </div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger alert-dismissible">
                @_error
                <button type="button" class="btn-close" @onclick="() => _error = null"></button>
            </div>
        }

        @switch (_activeTab)
        {
            case "Pendente":
                @if (_loading)
                {
                    <p>Lade Anfragen…</p>
                }
                else if (!_pending.Any())
                {
                    <div class="alert alert-info">Keine ausstehenden Anfragen.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Datum / Zeit</th>
                                    <th>Mieter</th>
                                    <th>Bezeichnung</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _pending)
                                {
                                    var slot = item.Slot;
                                    var member = item.Member;
                                    <tr>
                                        <td>@FormatSlot(slot.Slot.StartUtc, slot.Slot.EndUtc)</td>
                                        <td>
                                            @if (member is not null)
                                            {
                                                <span>@member.ContactPerson</span><br />
                                                <small class="text-muted">@member.Email</small>
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td>@(slot.Title ?? "–")</td>
                                        <td>
                                            <button class="btn btn-sm btn-success me-1"
                                                    @onclick="() => ConfirmAsync(slot.Id)">
                                                Bestätigen
                                            </button>
                                            <button class="btn btn-sm btn-danger"
                                                    @onclick="() => OpenRejectDialog(slot.Id)">
                                                Ablehnen
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                break;

            case "Alle Buchungen":
                <div class="d-flex align-items-center gap-3 mb-3">
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="() => ShiftWeekAsync(-7)">&#8249; Vorwoche</button>
                    <strong>KW @GetIsoWeek(_adminWeek): @_adminWeek.ToString("d. MMM") – @_adminWeek.AddDays(6).ToString("d. MMM yyyy")</strong>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="() => ShiftWeekAsync(7)">Nächste Woche &#8250;</button>
                </div>
                @if (_loadingWeek)
                {
                    <p>Lade…</p>
                }
                else if (!_weekSlots.Any())
                {
                    <p class="text-muted">Keine Buchungen in dieser Woche.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead><tr><th>Zeit</th><th>Dauer</th><th>Bezeichnung</th><th>Typ</th></tr></thead>
                            <tbody>
                                @foreach (var ws in _weekSlots)
                                {
                                    <tr>
                                        <td>@FormatSlot(ws.StartUtc, ws.EndUtc)</td>
                                        <td>@((int)(ws.EndUtc - ws.StartUtc).TotalMinutes) min</td>
                                        <td>@(ws.Title ?? "–")</td>
                                        <td><span class="badge @TypeBadge(ws.Type)">@ws.Type</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                <div class="mt-3">
                    <strong>CSV-Export:</strong>
                    <div class="d-flex gap-2 align-items-center mt-1 flex-wrap">
                        <input type="date" class="form-control form-control-sm" style="width:160px"
                               @bind="_exportFrom" />
                        <span>bis</span>
                        <input type="date" class="form-control form-control-sm" style="width:160px"
                               @bind="_exportTo" />
                        <a href="@($"/api/admin/reservierungen/export?von={_exportFrom:yyyy-MM-dd}&bis={_exportTo:yyyy-MM-dd}")"
                           class="btn btn-sm btn-outline-secondary" target="_blank">
                            CSV herunterladen
                        </a>
                    </div>
                </div>
                break;

            case "Erfassen":
                <div class="card border-0 shadow-sm p-4" style="max-width:560px">
                    <h5 class="mb-4">Neuen Slot erfassen</h5>

                    @if (_erfassenError is not null)
                    {
                        <div class="alert alert-danger">@_erfassenError</div>
                    }
                    @if (_erfassenSuccess)
                    {
                        <div class="alert alert-success">Slot wurde erfolgreich erfasst.</div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Typ</label>
                        <select class="form-select" @bind="_erfassenTyp">
                            <option value="Blocker">Blocker — intern, nicht öffentlich</option>
                            <option value="Reserved">Reserved — unbestätigt (Mieter erforderlich)</option>
                            <option value="Booked">Booked — bestätigt (Mieter erforderlich)</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-semibold">Start</label>
                            <input type="datetime-local" class="form-control"
                                   @bind="_erfassenStart" @bind:format="yyyy-MM-ddTHH:mm" />
                        </div>
                        <div class="col">
                            <label class="form-label fw-semibold">Ende</label>
                            <input type="datetime-local" class="form-control"
                                   @bind="_erfassenEnde" @bind:format="yyyy-MM-ddTHH:mm" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bezeichnung</label>
                        <input type="text" class="form-control" placeholder="z.B. Vereinstraining, Wartung, …"
                               @bind="_erfassenTitel" />
                    </div>

                    @if (_erfassenTyp != "Blocker")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mitglied-ID</label>
                            <input type="number" class="form-control" placeholder="Umbraco Member-ID"
                                   @bind="_erfassenMitgliedId" />
                        </div>
                    }

                    <div class="mb-3">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="farbeCheck"
                                   @bind="_erfassenFarbeAktiv" />
                            <label class="form-check-label" for="farbeCheck">Farbe setzen</label>
                        </div>
                        @if (_erfassenFarbeAktiv)
                        {
                            <input type="color" class="form-control form-control-color"
                                   @bind="_erfassenFarbe" style="width:80px" />
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Notizen (optional)</label>
                        <textarea class="form-control" rows="2" placeholder="Interne Bemerkungen"
                                  @bind="_erfassenNotizen"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="ErfassenAsync">Speichern</button>
                        <button class="btn btn-outline-secondary" @onclick="ErfassenReset">Zurücksetzen</button>
                    </div>
                </div>
                break;
        }

    </div>
</div>

@if (_rejectSlotId is not null)
{
    <div class="modal-overlay position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background:rgba(0,0,0,.5);z-index:1050">
        <div class="card p-4" style="min-width:340px;max-width:480px">
            <h5>Buchung ablehnen</h5>
            <textarea class="form-control mb-3" @bind="_rejectReason" rows="3"
                      placeholder="Ablehnungsgrund (optional)"></textarea>
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="ConfirmRejectAsync">Ablehnen</button>
                <button class="btn btn-secondary" @onclick="CancelReject">Abbrechen</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";

    private static readonly TimeZoneInfo Zurich =
        TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time");

    private static readonly string[] _tabs = ["Pendente", "Alle Buchungen", "Erfassen"];
    private string _activeTab = "Pendente";

    private IReadOnlyList<(SporthalleWeb.Domain.Reservierung.BookingSlot Slot, SporthalleWeb.Domain.Reservierung.HallMember? Member)> _pending = [];
    private IReadOnlyList<SporthalleWeb.Application.Reservierung.WeekSlotDto> _weekSlots = [];

    private bool _loading = true;
    private bool _loadingWeek;
    private string? _message;
    private string? _error;

    private int? _rejectSlotId;
    private string? _rejectReason;

    private DateTime _adminWeek = DateTime.Today.AddDays(-(((int)DateTime.Today.DayOfWeek + 6) % 7));
    private DateOnly _exportFrom = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateOnly _exportTo = DateOnly.FromDateTime(DateTime.Today);

    // Erfassen
    private string _erfassenTyp = "Blocker";
    private DateTime _erfassenStart = DateTime.Today.AddHours(8);
    private DateTime _erfassenEnde = DateTime.Today.AddHours(12);
    private string _erfassenTitel = "";
    private int? _erfassenMitgliedId;
    private bool _erfassenFarbeAktiv;
    private string _erfassenFarbe = "#3498db";
    private string? _erfassenNotizen;
    private string? _erfassenError;
    private bool _erfassenSuccess;

    protected override async Task OnInitializedAsync() => await LoadPendingAsync();

    private async Task LoadPendingAsync()
    {
        _loading = true;
        _message = null;
        _error = null;
        _pending = await AdminService.GetPendingAsync();
        _loading = false;
    }

    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        _erfassenSuccess = false;
        _erfassenError = null;
        if (tab == "Alle Buchungen" && !_weekSlots.Any())
            await LoadWeekAsync();
    }

    private async Task LoadWeekAsync()
    {
        _loadingWeek = true;
        var monday = DateOnly.FromDateTime(_adminWeek);
        _weekSlots = await WeekSlotsQuery.ExecuteAsync(monday);
        _loadingWeek = false;
    }

    private async Task ShiftWeekAsync(int days)
    {
        _adminWeek = _adminWeek.AddDays(days);
        await LoadWeekAsync();
    }

    private async Task ConfirmAsync(int slotId)
    {
        ClearMessages();
        try
        {
            await ConfirmUseCase.ExecuteAsync(slotId, AdminUser);
            _message = $"Buchung #{slotId} wurde bestätigt.";
            await LoadPendingAsync();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _error = ex.Message; }
    }

    private void OpenRejectDialog(int id) { _rejectSlotId = id; _rejectReason = null; }

    private async Task ConfirmRejectAsync()
    {
        if (_rejectSlotId is null) return;
        ClearMessages();
        try
        {
            await RejectUseCase.ExecuteAsync(_rejectSlotId.Value, _rejectReason ?? "", AdminUser);
            _message = $"Buchung #{_rejectSlotId} wurde abgelehnt.";
            _rejectSlotId = null;
            await LoadPendingAsync();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _error = ex.Message; }
    }

    private void CancelReject() { _rejectSlotId = null; _rejectReason = null; }

    private void ClearMessages() { _message = null; _error = null; }

    private async Task ErfassenAsync()
    {
        _erfassenError = null;
        _erfassenSuccess = false;

        if (string.IsNullOrWhiteSpace(_erfassenTitel))
        {
            _erfassenError = "Bezeichnung ist erforderlich.";
            return;
        }
        if (_erfassenStart >= _erfassenEnde)
        {
            _erfassenError = "Ende muss nach dem Start liegen.";
            return;
        }
        if (_erfassenTyp != "Blocker" && _erfassenMitgliedId is null)
        {
            _erfassenError = "Mitglied-ID ist für Reserved und Booked erforderlich.";
            return;
        }

        if (!Enum.TryParse<SporthalleWeb.Domain.Reservierung.SlotType>(_erfassenTyp, out var typ))
        {
            _erfassenError = "Ungültiger Typ.";
            return;
        }

        var startUtc = DateTime.SpecifyKind(
            TimeZoneInfo.ConvertTimeToUtc(
                DateTime.SpecifyKind(_erfassenStart, DateTimeKind.Unspecified), Zurich),
            DateTimeKind.Utc);
        var endUtc = DateTime.SpecifyKind(
            TimeZoneInfo.ConvertTimeToUtc(
                DateTime.SpecifyKind(_erfassenEnde, DateTimeKind.Unspecified), Zurich),
            DateTimeKind.Utc);

        try
        {
            await AdminService.CreateSlotAsync(
                typ, startUtc, endUtc,
                _erfassenTitel.Trim(),
                _erfassenFarbeAktiv ? _erfassenFarbe : null,
                string.IsNullOrWhiteSpace(_erfassenNotizen) ? null : _erfassenNotizen.Trim(),
                _erfassenMitgliedId,
                AdminUser);
            _erfassenSuccess = true;
            ErfassenReset();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _erfassenError = ex.Message; }
    }

    private void ErfassenReset()
    {
        _erfassenTyp = "Blocker";
        _erfassenStart = DateTime.Today.AddHours(8);
        _erfassenEnde = DateTime.Today.AddHours(12);
        _erfassenTitel = "";
        _erfassenMitgliedId = null;
        _erfassenFarbeAktiv = false;
        _erfassenFarbe = "#3498db";
        _erfassenNotizen = null;
        _erfassenError = null;
    }

    private string FormatSlot(DateTime startUtc, DateTime endUtc)
    {
        var start = TimeZoneInfo.ConvertTimeFromUtc(startUtc, Zurich);
        var end = TimeZoneInfo.ConvertTimeFromUtc(endUtc, Zurich);
        return $"{start:ddd d. MMM yyyy HH:mm} – {end:HH:mm}";
    }

    private static string TypeBadge(string type) => type switch
    {
        "Booked"   => "bg-success",
        "Reserved" => "bg-warning text-dark",
        "Blocker"  => "bg-secondary",
        _ => "bg-secondary"
    };

    private static int GetIsoWeek(DateTime date)
    {
        var cal = System.Globalization.CultureInfo.GetCultureInfo("de-CH").Calendar;
        return cal.GetWeekOfYear(date, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    }
}
