@using Microsoft.JSInterop
@inject SporthalleWeb.Application.Reservierung.BookingAdminService AdminService
@inject SporthalleWeb.Application.Reservierung.ConfirmBookingUseCase ConfirmUseCase
@inject SporthalleWeb.Application.Reservierung.RejectBookingUseCase RejectUseCase
@inject SporthalleWeb.Application.Reservierung.HallConfigService Config
@inject IJSRuntime JS
@implements IDisposable

<style>
    .reservierung-admin { height: 100%; display: flex; flex-direction: column; }

    .admin-subnav {
        background: #1e4d82;
        display: flex;
        align-items: stretch;
        padding: 0 0.5rem;
        flex-shrink: 0;
    }
    .subnav-btn {
        color: rgba(255, 255, 255, 0.75);
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.7rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: color 0.15s ease, background 0.15s ease;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .subnav-btn:hover { color: #fff; background: rgba(255,255,255,0.1); }
    .subnav-btn.active { color: #fff; border-bottom-color: #5dade2; }

    .admin-content { padding: 1.5rem; flex: 1; overflow-y: auto; }

    /* Edit-Dialog Tageskalender */
    .ec-slot-selected { background: rgba(37, 99, 235, 0.15); }
    .ec-slot-conflict  { background: rgba(220, 38, 38, 0.2); cursor: not-allowed !important; }
    .ec-slot-booked    { background: rgba(100, 100, 100, 0.12); cursor: not-allowed !important; }
    .ec-drag           { background: rgba(37, 99, 235, 0.3) !important; }
</style>

<div class="reservierung-admin">

    <nav class="admin-subnav">
        @foreach (var tab in _tabs)
        {
            <button class="subnav-btn @(_activeTab == tab ? "active" : "")"
                    @onclick="() => SetTab(tab)">
                @tab
                @if (tab == "Anfragen" && _pending.Count > 0)
                {
                    <span class="badge bg-danger">@_pending.Count</span>
                }
            </button>
        }
    </nav>

    <div class="admin-content">

        @if (_message is not null)
        {
            <div class="alert alert-success alert-dismissible">
                @_message
                <button type="button" class="btn-close" @onclick="() => _message = null"></button>
            </div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger alert-dismissible">
                @_error
                <button type="button" class="btn-close" @onclick="() => _error = null"></button>
            </div>
        }

        @switch (_activeTab)
        {
            // ── Anfragen ──────────────────────────────────────────────────────
            case "Anfragen":
                @if (_loading)
                {
                    <p>Lade Anfragen…</p>
                }
                else if (!_pending.Any())
                {
                    <div class="alert alert-info">Keine ausstehenden Anfragen.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" style="font-size:0.875rem">
                            <thead>
                                <tr>
                                    <th style="white-space:nowrap">Eingegangen</th>
                                    <th style="white-space:nowrap">Termin</th>
                                    <th>Anlass</th>
                                    <th>Mieter</th>
                                    <th>Rechnungsadresse</th>
                                    <th>Kontakt</th>
                                    <th>Bemerkungen</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _pending)
                                {
                                    var slot = item.Slot;
                                    var member = item.Member;
                                    <tr>
                                        <td style="white-space:nowrap">
                                            @{ var eingegangen = TimeZoneInfo.ConvertTimeFromUtc(slot.CreatedAt, Zurich); }
                                            @eingegangen.ToString("d. MMM yyyy", DeCh)<br />
                                            <small class="text-muted">@eingegangen.ToString("HH:mm", DeCh)</small>
                                        </td>
                                        <td style="white-space:nowrap">
                                            @FormatSlot(slot.Slot.StartUtc, slot.Slot.EndUtc)<br />
                                            <small class="text-muted">@((int)(slot.Slot.EndUtc - slot.Slot.StartUtc).TotalMinutes) min</small>
                                        </td>
                                        <td>@(slot.Title ?? "–")</td>
                                        <td>
                                            @if (member is not null)
                                            {
                                                <strong>@member.ContactPerson</strong>
                                                <br /><small class="text-muted">@member.RenterType.Value</small>
                                                @if (!string.IsNullOrEmpty(member.BillingName) && member.BillingName != member.ContactPerson)
                                                {
                                                    <br /><small class="text-muted">@member.BillingName</small>
                                                }
                                                @if (member.HasKey)
                                                {
                                                    <br /><span class="badge bg-secondary mt-1" style="font-size:0.7rem">Hat Schlüssel</span>
                                                }
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td>
                                            @if (member is not null)
                                            {
                                                <span>@member.BillingAddress</span><br />
                                                <span>@member.BillingPostalCode @member.BillingCity</span>
                                                @if (!string.IsNullOrEmpty(member.BillingCountry) &&
                                                     member.BillingCountry != "CH" &&
                                                     member.BillingCountry != "Schweiz")
                                                {
                                                    <br /><small class="text-muted">@member.BillingCountry</small>
                                                }
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td>
                                            @if (member is not null)
                                            {
                                                <a href="mailto:@member.Email">@member.Email</a>
                                                @if (!string.IsNullOrEmpty(member.Phone))
                                                {
                                                    <br /><small>@member.Phone</small>
                                                }
                                            }
                                        </td>
                                        <td style="max-width:200px">
                                            @if (!string.IsNullOrEmpty(slot.Notes))
                                            {
                                                <span style="white-space:pre-wrap;font-size:0.85rem">@slot.Notes</span>
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td style="white-space:nowrap">
                                            <button class="btn btn-sm btn-success me-1"
                                                    @onclick="() => OpenConfirmDialog(slot.Id)">
                                                Bestätigen
                                            </button>
                                            <button class="btn btn-sm btn-danger"
                                                    @onclick="() => OpenRejectDialog(slot.Id)">
                                                Ablehnen
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                break;

            // ── Buchungen ─────────────────────────────────────────────────────
            case "Buchungen":
                <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">

                    @{ var modes = new[] { "Tag", "Woche", "Monat" }; }
                    <div class="btn-group btn-group-sm" role="group">
                        @foreach (var m in modes)
                        {
                            <button type="button"
                                    class="btn @(_viewMode == m ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SetViewModeAsync(m)">@m</button>
                        }
                    </div>

                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShiftPeriodAsync(-1)">@PrevLabel</button>
                    <strong>@PeriodTitle</strong>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShiftPeriodAsync(1)">@NextLabel</button>
                    <button class="btn btn-sm btn-link p-0 ms-1 text-secondary" @onclick="GoToTodayAsync">Heute</button>

                    <div class="form-check mb-0 ms-auto">
                        <input class="form-check-input" type="checkbox" id="chk-show-rejected"
                               @bind="_showRejected" @bind:after="LoadPeriodAsync" />
                        <label class="form-check-label" for="chk-show-rejected">Abgelehnte anzeigen</label>
                    </div>

                </div>

                @if (_loadingPeriod)
                {
                    <p>Lade…</p>
                }
                else if (!_periodSlots.Any())
                {
                    <p class="text-muted">Keine Buchungen in diesem Zeitraum.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" style="font-size:0.875rem">
                            <thead>
                                <tr>
                                    <th style="white-space:nowrap">Eingegangen</th>
                                    <th style="white-space:nowrap">Termin</th>
                                    <th>Anlass</th>
                                    <th>Typ</th>
                                    <th>Mieter</th>
                                    <th>Rechnungsadresse</th>
                                    <th>Kontakt</th>
                                    <th>Bemerkungen</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _periodSlots)
                                {
                                    var s = item.Slot;
                                    var m = item.Member;
                                    <tr class="@(s.Type == SporthalleWeb.Domain.Reservierung.SlotType.Rejected ? "table-light text-muted" : "")">
                                        <td style="white-space:nowrap">
                                            @{ var eingegangen = TimeZoneInfo.ConvertTimeFromUtc(s.CreatedAt, Zurich); }
                                            @eingegangen.ToString("d. MMM yyyy", DeCh)<br />
                                            <small class="text-muted">@eingegangen.ToString("HH:mm", DeCh)</small>
                                        </td>
                                        <td style="white-space:nowrap">
                                            @FormatSlot(s.Slot.StartUtc, s.Slot.EndUtc)<br />
                                            <small class="text-muted">@((int)(s.Slot.EndUtc - s.Slot.StartUtc).TotalMinutes) min</small>
                                        </td>
                                        <td>@(s.Title ?? "–")</td>
                                        <td><span class="badge @TypeBadge(s.Type.ToString())">@TypeLabel(s.Type)</span></td>
                                        <td>
                                            @if (m is not null)
                                            {
                                                <strong>@m.ContactPerson</strong>
                                                <br /><small class="text-muted">@m.RenterType.Value</small>
                                                @if (!string.IsNullOrEmpty(m.BillingName) && m.BillingName != m.ContactPerson)
                                                {
                                                    <br /><small class="text-muted">@m.BillingName</small>
                                                }
                                                @if (m.HasKey)
                                                {
                                                    <br /><span class="badge bg-secondary mt-1" style="font-size:0.7rem">Hat Schlüssel</span>
                                                }
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td>
                                            @if (m is not null)
                                            {
                                                <span>@m.BillingAddress</span><br />
                                                <span>@m.BillingPostalCode @m.BillingCity</span>
                                                @if (!string.IsNullOrEmpty(m.BillingCountry) &&
                                                     m.BillingCountry != "CH" &&
                                                     m.BillingCountry != "Schweiz")
                                                {
                                                    <br /><small class="text-muted">@m.BillingCountry</small>
                                                }
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td>
                                            @if (m is not null)
                                            {
                                                <a href="mailto:@m.Email">@m.Email</a>
                                                @if (!string.IsNullOrEmpty(m.Phone))
                                                {
                                                    <br /><small>@m.Phone</small>
                                                }
                                            }
                                        </td>
                                        <td style="max-width:200px">
                                            @if (!string.IsNullOrEmpty(s.Notes))
                                            {
                                                <span style="white-space:pre-wrap;font-size:0.85rem">@s.Notes</span>
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td style="white-space:nowrap">
                                            @if (s.Type != SporthalleWeb.Domain.Reservierung.SlotType.Rejected)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => OpenEditDialog(s.Id)">Bearbeiten</button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-success"
                                                        @onclick="() => ReactivateAsync(s.Id)">Reaktivieren</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="mt-3 d-flex align-items-center gap-2 flex-wrap">
                    <a href="@($"/api/admin/reservierungen/export?von={PeriodFrom:yyyy-MM-dd}&bis={PeriodTo:yyyy-MM-dd}")"
                       class="btn btn-sm btn-outline-secondary" target="_blank">
                        CSV herunterladen
                    </a>
                    <small class="text-muted">@PeriodFrom.ToString("d. MMM", DeCh) – @PeriodTo.ToString("d. MMM yyyy", DeCh)</small>
                </div>
                break;

            // ── Blocker ───────────────────────────────────────────────────────
            case "Blocker":
                <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">

                    @{ var blockerModes = new[] { "Tag", "Woche", "Monat" }; }
                    <div class="btn-group btn-group-sm" role="group">
                        @foreach (var m in blockerModes)
                        {
                            <button type="button"
                                    class="btn @(_blockerViewMode == m ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SetBlockerViewModeAsync(m)">@m</button>
                        }
                    </div>

                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShiftBlockerAsync(-1)">@BlockerPrevLabel</button>
                    <strong>@BlockerTitle</strong>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShiftBlockerAsync(1)">@BlockerNextLabel</button>
                    <button class="btn btn-sm btn-link p-0 ms-1 text-secondary" @onclick="GoToBlockerTodayAsync">Heute</button>

                </div>

                @if (_loadingBlocker)
                {
                    <p>Lade…</p>
                }
                else if (!_blockerSlots.Any())
                {
                    <p class="text-muted">Keine Blocker in diesem Zeitraum.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" style="font-size:0.875rem">
                            <thead>
                                <tr>
                                    <th style="white-space:nowrap">Erstellt</th>
                                    <th style="white-space:nowrap">Termin</th>
                                    <th>Bezeichnung</th>
                                    <th>Bemerkungen</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in _blockerSlots)
                                {
                                    <tr>
                                        <td style="white-space:nowrap">
                                            @{ var erstellt = TimeZoneInfo.ConvertTimeFromUtc(b.CreatedAt, Zurich); }
                                            @erstellt.ToString("d. MMM yyyy", DeCh)<br />
                                            <small class="text-muted">@erstellt.ToString("HH:mm", DeCh)</small>
                                        </td>
                                        <td style="white-space:nowrap">
                                            @FormatSlot(b.Slot.StartUtc, b.Slot.EndUtc)<br />
                                            <small class="text-muted">@((int)(b.Slot.EndUtc - b.Slot.StartUtc).TotalMinutes) min</small>
                                        </td>
                                        <td>@(b.Title ?? "–")</td>
                                        <td style="max-width:250px">
                                            @if (!string.IsNullOrEmpty(b.Notes))
                                            {
                                                <span style="white-space:pre-wrap;font-size:0.85rem">@b.Notes</span>
                                            }
                                            else { <span class="text-muted">–</span> }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => OpenEditDialog(b.Id)">Bearbeiten</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                break;

            // ── Erfassen ──────────────────────────────────────────────────────
            case "Erfassen":
                <AdminErfassenComponent AdminUser="@AdminUser" />
                break;

            // ── Konfiguration ─────────────────────────────────────────────────
            case "Konfiguration":
                <AdminKonfigurationComponent />
                break;
        }

    </div>
</div>

@if (_confirmSlotId is not null)
{
    <div class="modal-overlay position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background:rgba(0,0,0,.5);z-index:1050">
        <div class="card" style="min-width:380px;max-width:540px;max-height:90vh;overflow-y:auto">
            <div class="card-header"><strong>Buchung bestätigen</strong></div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Buchungsanfrage #@_confirmSlotId wird bestätigt. E-Mail-Text kann unten angepasst werden.
                </p>
                @if (_confirmEmailLoading)
                {
                    <p class="text-muted small">Lade E-Mail-Vorschau…</p>
                }
                else
                {
                    <label class="form-label fw-semibold small">E-Mail-Text an Mieter</label>
                    <textarea class="form-control font-monospace" style="font-size:0.82rem"
                              @bind="_confirmEmailText" rows="7"></textarea>
                }
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CancelConfirm">Abbrechen</button>
                <button class="btn btn-success" @onclick="ConfirmConfirmAsync" disabled="@_confirmEmailLoading">Bestätigen &amp; senden</button>
            </div>
        </div>
    </div>
}

@if (_rejectSlotId is not null)
{
    <div class="modal-overlay position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background:rgba(0,0,0,.5);z-index:1050">
        <div class="card" style="min-width:380px;max-width:540px;max-height:90vh;overflow-y:auto">
            <div class="card-header"><strong>Buchung ablehnen</strong></div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Interner Ablehnungsgrund (optional)</label>
                    <textarea class="form-control" @bind="_rejectReason" rows="2"
                              placeholder="Wird nicht an den Mieter gesendet"></textarea>
                </div>
                @if (_rejectEmailLoading)
                {
                    <p class="text-muted small">Lade E-Mail-Vorschau…</p>
                }
                else
                {
                    <label class="form-label fw-semibold small">E-Mail-Text an Mieter</label>
                    <textarea class="form-control font-monospace" style="font-size:0.82rem"
                              @bind="_rejectEmailText" rows="6"></textarea>
                }
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CancelReject">Abbrechen</button>
                <button class="btn btn-danger" @onclick="ConfirmRejectAsync" disabled="@_rejectEmailLoading">Ablehnen &amp; senden</button>
            </div>
        </div>
    </div>
}

@if (_editSlotId is not null)
{
    <div class="modal-overlay position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background:rgba(0,0,0,.5);z-index:1050">
        <div class="card" style="min-width:540px;max-width:700px;max-height:90vh;overflow-y:auto">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@(_editSlotType == SporthalleWeb.Domain.Reservierung.SlotType.Blocker ? "Blocker bearbeiten" : "Buchung bearbeiten")</strong>
                <span class="badge @TypeBadge(_editSlotType.ToString())">@TypeLabel(_editSlotType)</span>
            </div>
            <div class="card-body">
                @if (_editLoading)
                {
                    <p>Lade…</p>
                }
                else
                {
                    <!-- Tag-Picker (Schweizer Datumsformat als Label) -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tag</label>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <input type="date" class="form-control" style="max-width:175px"
                                   value="@_editStartDate"
                                   @onchange="OnEditDayChangedAsync" />
                            @if (DateOnly.TryParse(_editStartDate, out var editDayLabel))
                            {
                                <span class="text-muted">@editDayLabel.ToString("dddd, d. MMMM yyyy", DeCh)</span>
                            }
                        </div>
                    </div>

                    <!-- Tageskalender: Uhrzeit via aufziehen wählen -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Uhrzeit <small class="text-muted fw-normal">(aufziehen zum Wählen)</small>
                        </label>
                        <div id="ec-@_editSlotId"
                             style="border:1px solid #dee2e6;border-radius:6px;overflow-y:auto;overflow-x:hidden;max-height:420px;user-select:none;cursor:crosshair">
                            @{
                                var calSlotCount = (_calEnd - _calStart) * 2;
                                var loSel = (_editSelStart >= 0 && _editSelEnd >= 0) ? Math.Min(_editSelStart, _editSelEnd) : -1;
                                var hiSel = (_editSelStart >= 0 && _editSelEnd >= 0) ? Math.Max(_editSelStart, _editSelEnd) : -1;
                            }
                            @for (int si = 0; si < calSlotCount; si++)
                            {
                                var slotIdx = si;
                                var slotH = _calStart + slotIdx / 2;
                                var slotM = (slotIdx % 2) * 30;
                                var isHour = slotM == 0;
                                var inSel = loSel >= 0 && slotIdx >= loSel && slotIdx <= hiSel;
                                var otherBooking = GetExistingBookingAtSlot(slotIdx);
                                var cellClass = GetSlotCssClass(inSel, otherBooking);

                                <div data-slot-idx="@slotIdx"
                                     data-booked="@(otherBooking != null ? "1" : "0")"
                                     class="@cellClass"
                                     style="display:flex;height:22px;@(isHour ? "border-top:1px solid #dee2e6;" : "border-top:1px dotted #f0f0f0;")">
                                    <div style="width:46px;flex-shrink:0;font-size:0.68rem;line-height:22px;
                                                color:#adb5bd;text-align:right;padding-right:6px;
                                                border-right:1px solid #dee2e6;background:#f8f9fa">
                                        @(isHour ? $"{slotH:00}:00" : "")
                                    </div>
                                    <div style="flex:1;padding-left:6px;line-height:22px;font-size:0.7rem;overflow:hidden;white-space:nowrap">
                                        @if (otherBooking is not null && isHour)
                                        {
                                            <span class="text-muted">@otherBooking.Title</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Gewählte Zeit + Verfügbarkeitsstatus -->
                        @if (_editSelStart >= 0 && _editSelEnd >= 0)
                        {
                            <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
                                <span class="fw-semibold">@_editStartTime – @_editEndTime Uhr</span>
                                @if (_editConflict)
                                {
                                    <span class="badge bg-danger">Zeitraum belegt</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Verfügbar</span>
                                }
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">@(_editSlotType == SporthalleWeb.Domain.Reservierung.SlotType.Blocker ? "Bezeichnung" : "Anlass") *</label>
                        <input class="form-control" @bind="_editTitle" />
                    </div>

                    @if (_editSlotType != SporthalleWeb.Domain.Reservierung.SlotType.Blocker)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Farbe</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var c in new[] { "#F1C40F","#C0392B","#1F4E79","#2B4C7E","#1E5E4A","#4A5568","#8C3A5C","#A8522A","#4A3762","#1A5A66","#3A563C","#5C4033" })
                                {
                                    <button type="button"
                                            style="width:26px;height:26px;background:@c;border-radius:4px;border: @(_editColor == c ? "3px solid #333" : "2px solid transparent");cursor:pointer"
                                            @onclick="() => _editColor = c"
                                            title="@c"></button>
                                }
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bemerkungen</label>
                        <textarea class="form-control" @bind="_editNotes" rows="3"></textarea>
                    </div>

                    @if (_editHasMember)
                    {
                        <hr />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">E-Mail</label>
                            <input class="form-control" value="@_editEmail" readonly />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-8">
                                <label class="form-label fw-semibold">Kontaktperson</label>
                                <input class="form-control" @bind="_editContactPerson" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold">Telefon</label>
                                <input class="form-control" @bind="_editPhone" type="tel" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mietertyp</label>
                            <select class="form-select" @bind="_editRenterType">
                                <option value="Privatperson">Privatperson</option>
                                <option value="Verein">Verein</option>
                                <option value="Firma">Firma</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Rechnungsname</label>
                            <input class="form-control" @bind="_editBillingName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Rechnungsadresse</label>
                            <input class="form-control" @bind="_editBillingAddress" />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold">PLZ</label>
                                <input class="form-control" @bind="_editBillingPostalCode" />
                            </div>
                            <div class="col-sm-8">
                                <label class="form-label fw-semibold">Ort</label>
                                <input class="form-control" @bind="_editBillingCity" />
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CancelEdit">Abbrechen</button>
                <button class="btn btn-primary" @onclick="SaveEditAsync"
                        disabled="@(_editLoading || _editConflict)">Speichern</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";

    private static readonly TimeZoneInfo Zurich =
        TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time");
    private static readonly System.Globalization.CultureInfo DeCh =
        System.Globalization.CultureInfo.GetCultureInfo("de-CH");

    private static readonly string[] _tabs = ["Anfragen", "Buchungen", "Blocker", "Erfassen", "Konfiguration"];
    private string _activeTab = "Anfragen";

    // ── Anfragen ─────────────────────────────────────────────────────────────
    private IReadOnlyList<(SporthalleWeb.Domain.Reservierung.BookingSlot Slot, SporthalleWeb.Domain.Reservierung.HallMember? Member)> _pending = [];
    private bool _loading = true;

    // ── Buchungen ────────────────────────────────────────────────────────────
    private string _viewMode = "Woche";
    private DateOnly _anchor = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<(SporthalleWeb.Domain.Reservierung.BookingSlot Slot, SporthalleWeb.Domain.Reservierung.HallMember? Member)> _periodSlots = [];
    private bool _loadingPeriod;
    private bool _showRejected;

    private static DateOnly CalcFrom(string viewMode, DateOnly anchor) => viewMode switch
    {
        "Tag"   => anchor,
        "Monat" => new DateOnly(anchor.Year, anchor.Month, 1),
        _       => GetMonday(anchor)
    };

    private static DateOnly CalcTo(string viewMode, DateOnly anchor) => viewMode switch
    {
        "Tag"   => anchor,
        "Monat" => new DateOnly(anchor.Year, anchor.Month, DateTime.DaysInMonth(anchor.Year, anchor.Month)),
        _       => GetMonday(anchor).AddDays(6)
    };

    private DateOnly PeriodFrom => CalcFrom(_viewMode, _anchor);
    private DateOnly PeriodTo   => CalcTo(_viewMode, _anchor);

    private string PeriodTitle => _viewMode switch
    {
        "Tag"   => _anchor.ToString("dddd, d. MMMM yyyy", DeCh),
        "Monat" => _anchor.ToString("MMMM yyyy", DeCh),
        _       => $"KW {GetIsoWeek(PeriodFrom.ToDateTime(TimeOnly.MinValue))}: " +
                   $"{PeriodFrom.ToString("d. MMM", DeCh)} – {PeriodTo.ToString("d. MMM yyyy", DeCh)}"
    };

    private string PrevLabel => _viewMode switch
    {
        "Tag"   => "‹ Vortag",
        "Monat" => "‹ Vormonat",
        _       => "‹ Vorwoche"
    };

    private string NextLabel => _viewMode switch
    {
        "Tag"   => "Nächster Tag ›",
        "Monat" => "Nächster Monat ›",
        _       => "Nächste Woche ›"
    };

    // ── Blocker ──────────────────────────────────────────────────────────────
    private string _blockerViewMode = "Woche";
    private DateOnly _blockerAnchor = DateOnly.FromDateTime(DateTime.Today);
    private IReadOnlyList<SporthalleWeb.Domain.Reservierung.BookingSlot> _blockerSlots = [];
    private bool _loadingBlocker;

    private DateOnly BlockerFrom  => CalcFrom(_blockerViewMode, _blockerAnchor);
    private DateOnly BlockerTo    => CalcTo(_blockerViewMode, _blockerAnchor);

    private string BlockerTitle => _blockerViewMode switch
    {
        "Tag"   => _blockerAnchor.ToString("dddd, d. MMMM yyyy", DeCh),
        "Monat" => _blockerAnchor.ToString("MMMM yyyy", DeCh),
        _       => $"KW {GetIsoWeek(BlockerFrom.ToDateTime(TimeOnly.MinValue))}: " +
                   $"{BlockerFrom.ToString("d. MMM", DeCh)} – {BlockerTo.ToString("d. MMM yyyy", DeCh)}"
    };

    private string BlockerPrevLabel => _blockerViewMode switch
    {
        "Tag"   => "‹ Vortag",
        "Monat" => "‹ Vormonat",
        _       => "‹ Vorwoche"
    };

    private string BlockerNextLabel => _blockerViewMode switch
    {
        "Tag"   => "Nächster Tag ›",
        "Monat" => "Nächster Monat ›",
        _       => "Nächste Woche ›"
    };

    // ── Shared ───────────────────────────────────────────────────────────────
    private string? _message;
    private string? _error;
    private int? _confirmSlotId;
    private string _confirmEmailText = "";
    private bool _confirmEmailLoading;
    private int? _rejectSlotId;
    private string? _rejectReason;
    private string _rejectEmailText = "";
    private bool _rejectEmailLoading;

    // ── Edit dialog ──────────────────────────────────────────────────────────
    private int? _editSlotId;
    private SporthalleWeb.Domain.Reservierung.SlotType _editSlotType;
    private string _editTitle = "";
    private string? _editColor;
    private string _editNotes = "";
    private bool _editHasMember;
    private int? _editMemberId;
    private string _editEmail = "";
    private string _editContactPerson = "";
    private string _editPhone = "";
    private string _editRenterType = "";
    private string _editBillingName = "";
    private string _editBillingAddress = "";
    private string _editBillingPostalCode = "";
    private string _editBillingCity = "";
    private string _editStartDate = "";
    private string _editStartTime = "";
    private string _editEndDate = "";
    private string _editEndTime = "";
    private bool _editLoading;

    // ── Edit-Dialog Tageskalender ─────────────────────────────────────────────
    private int _editSelStart = -1;
    private int _editSelEnd   = -1;
    private bool _editConflict;
    private IReadOnlyList<SporthalleWeb.Domain.Reservierung.BookingSlot> _calendarSlotsForDay = [];
    private int _calStart = 7;
    private int _calEnd   = 23;
    private DotNetObjectReference<ReservierungAdminComponent>? _dotNetRef;
    private int? _calInitializedForSlotId;

    protected override async Task OnInitializedAsync() => await LoadPendingAsync();

    private async Task LoadPendingAsync()
    {
        _loading = true;
        _message = null;
        _error = null;
        _pending = await AdminService.GetPendingAsync();
        _loading = false;
    }

    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        _message = null;
        _error = null;
        if (tab == "Anfragen")
            await LoadPendingAsync();
        else if (tab == "Buchungen")
            await LoadPeriodAsync();
        else if (tab == "Blocker")
            await LoadBlockerAsync();
    }

    // ── Buchungen ────────────────────────────────────────────────────────────

    private async Task LoadPeriodAsync()
    {
        _loadingPeriod = true;
        _periodSlots = await AdminService.GetSlotsWithMembersForPeriodAsync(PeriodFrom, PeriodTo, _showRejected);
        _loadingPeriod = false;
    }

    private async Task SetViewModeAsync(string mode)
    {
        _viewMode = mode;
        await LoadPeriodAsync();
    }

    private async Task ShiftPeriodAsync(int direction)
    {
        _anchor = _viewMode switch
        {
            "Tag"   => _anchor.AddDays(direction),
            "Monat" => _anchor.AddMonths(direction),
            _       => _anchor.AddDays(direction * 7)
        };
        await LoadPeriodAsync();
    }

    private async Task GoToTodayAsync()
    {
        _anchor = DateOnly.FromDateTime(DateTime.Today);
        await LoadPeriodAsync();
    }

    // ── Blocker ──────────────────────────────────────────────────────────────

    private async Task LoadBlockerAsync()
    {
        _loadingBlocker = true;
        _blockerSlots = await AdminService.GetBlockersForPeriodAsync(BlockerFrom, BlockerTo);
        _loadingBlocker = false;
    }

    private async Task SetBlockerViewModeAsync(string mode)
    {
        _blockerViewMode = mode;
        await LoadBlockerAsync();
    }

    private async Task ShiftBlockerAsync(int direction)
    {
        _blockerAnchor = _blockerViewMode switch
        {
            "Tag"   => _blockerAnchor.AddDays(direction),
            "Monat" => _blockerAnchor.AddMonths(direction),
            _       => _blockerAnchor.AddDays(direction * 7)
        };
        await LoadBlockerAsync();
    }

    private async Task GoToBlockerTodayAsync()
    {
        _blockerAnchor = DateOnly.FromDateTime(DateTime.Today);
        await LoadBlockerAsync();
    }

    // ── Pendente actions ─────────────────────────────────────────────────────

    private async Task OpenConfirmDialog(int id)
    {
        _confirmSlotId = id;
        _confirmEmailLoading = true;
        _confirmEmailText = "";
        var (slot, member) = await AdminService.FindSlotWithMemberAsync(id);
        if (slot is not null && member is not null)
        {
            var start = TimeZoneInfo.ConvertTimeFromUtc(slot.Slot.StartUtc, Zurich);
            var end   = TimeZoneInfo.ConvertTimeFromUtc(slot.Slot.EndUtc,   Zurich);
            var slotStr = $"{start.ToString("dddd, d. MMMM yyyy", DeCh)}, {start:HH:mm} – {end:HH:mm} Uhr";

            var configuredText = await Config.GetAsync("mail_bestaetigung_text");
            if (!string.IsNullOrWhiteSpace(configuredText))
            {
                _confirmEmailText = configuredText
                    .Replace("{Name}", member.ContactPerson)
                    .Replace("{Anlass}", slot.Title ?? "")
                    .Replace("{Datum}", start.ToString("dddd, d. MMMM yyyy", DeCh))
                    .Replace("{Von}", start.ToString("HH:mm"))
                    .Replace("{Bis}", end.ToString("HH:mm"));
            }
            else
            {
                _confirmEmailText =
                    $"Ihre Buchung für {slotStr} wurde bestätigt.\n\n" +
                    $"Anlass: {slot.Title}\n\n" +
                    "Bei Fragen wenden Sie sich bitte an reservierung@sporthalle-sulzerallee.ch.";
            }
        }
        _confirmEmailLoading = false;
    }

    private void CancelConfirm() { _confirmSlotId = null; }

    private async Task ConfirmConfirmAsync()
    {
        if (_confirmSlotId is null) return;
        var id = _confirmSlotId.Value;
        _confirmSlotId = null;
        ClearMessages();
        try
        {
            var body = string.IsNullOrWhiteSpace(_confirmEmailText) ? null : _confirmEmailText;
            await ConfirmUseCase.ExecuteAsync(id, AdminUser, body);
            _message = $"Buchung #{id} wurde bestätigt.";
            await LoadPendingAsync();
            if (_activeTab == "Buchungen") await LoadPeriodAsync();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _error = ex.Message; }
    }

    private async Task OpenRejectDialog(int id)
    {
        _rejectSlotId = id;
        _rejectReason = null;
        _rejectEmailLoading = true;
        _rejectEmailText = "";
        var (slot, member) = await AdminService.FindSlotWithMemberAsync(id);
        if (slot is not null && member is not null)
        {
            var start = TimeZoneInfo.ConvertTimeFromUtc(slot.Slot.StartUtc, Zurich);
            var end   = TimeZoneInfo.ConvertTimeFromUtc(slot.Slot.EndUtc,   Zurich);
            var slotStr = $"{start.ToString("dddd, d. MMMM yyyy", DeCh)}, {start:HH:mm} – {end:HH:mm} Uhr";
            _rejectEmailText =
                $"Leider können wir Ihre Buchungsanfrage für {slotStr} nicht bestätigen.\n\n" +
                "Bitte kontaktieren Sie uns unter reservierung@sporthalle-sulzerallee.ch " +
                "für weitere Informationen oder einen alternativen Termin.";
        }
        _rejectEmailLoading = false;
    }

    private async Task ConfirmRejectAsync()
    {
        if (_rejectSlotId is null) return;
        ClearMessages();
        try
        {
            var body = string.IsNullOrWhiteSpace(_rejectEmailText) ? null : _rejectEmailText;
            await RejectUseCase.ExecuteAsync(_rejectSlotId.Value, _rejectReason ?? "", AdminUser, body);
            _message = $"Buchung #{_rejectSlotId} wurde abgelehnt.";
            _rejectSlotId = null;
            await LoadPendingAsync();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _error = ex.Message; }
    }

    private void CancelReject() { _rejectSlotId = null; _rejectReason = null; }

    private void ClearMessages() { _message = null; _error = null; }

    // ── Helpers ──────────────────────────────────────────────────────────────

    private string FormatSlot(DateTime startUtc, DateTime endUtc)
    {
        var start = TimeZoneInfo.ConvertTimeFromUtc(startUtc, Zurich);
        var end   = TimeZoneInfo.ConvertTimeFromUtc(endUtc, Zurich);
        return $"{start.ToString("ddd d. MMM yyyy HH:mm", DeCh)} – {end:HH:mm}";
    }

    private static string TypeBadge(string type) => type switch
    {
        "Booked"    => "bg-success",
        "Reserved"  => "bg-warning text-dark",
        "Blocker"   => "bg-secondary",
        "Rejected"  => "bg-danger",
        _           => "bg-secondary"
    };

    private static string TypeLabel(SporthalleWeb.Domain.Reservierung.SlotType type) => type switch
    {
        SporthalleWeb.Domain.Reservierung.SlotType.Booked    => "Bestätigt",
        SporthalleWeb.Domain.Reservierung.SlotType.Reserved  => "Angefragt",
        SporthalleWeb.Domain.Reservierung.SlotType.Blocker   => "Blocker",
        SporthalleWeb.Domain.Reservierung.SlotType.Rejected  => "Abgelehnt",
        _ => type.ToString()
    };

    private async Task OpenEditDialog(int id)
    {
        _editSlotId = id;
        _editLoading = true;
        var (slot, member) = await AdminService.FindSlotWithMemberAsync(id);
        if (slot is null) { _editSlotId = null; _editLoading = false; return; }
        _editSlotType           = slot.Type;
        _editTitle              = slot.Title ?? "";
        _editColor              = slot.Color ?? "#C0392B";
        _editNotes              = slot.Notes ?? "";
        _editHasMember          = member is not null;
        _editMemberId           = member?.Id;
        _editEmail              = member?.Email ?? "";
        _editContactPerson      = member?.ContactPerson ?? "";
        _editPhone              = member?.Phone ?? "";
        _editRenterType         = member?.RenterType.Value.ToString() ?? "Privatperson";
        _editBillingName        = member?.BillingName ?? "";
        _editBillingAddress     = member?.BillingAddress ?? "";
        _editBillingPostalCode  = member?.BillingPostalCode ?? "";
        _editBillingCity        = member?.BillingCity ?? "";
        var startLocal = TimeZoneInfo.ConvertTimeFromUtc(slot.Slot.StartUtc, Zurich);
        var endLocal   = TimeZoneInfo.ConvertTimeFromUtc(slot.Slot.EndUtc,   Zurich);
        _editStartDate = startLocal.ToString("yyyy-MM-dd");
        _editStartTime = startLocal.ToString("HH:mm");
        _editEndDate   = _editStartDate; // Tageskalender: immer gleicher Tag
        _editEndTime   = endLocal.ToString("HH:mm");

        // Kalender-Konfiguration laden
        var cfgStart = await Config.GetAsync("kalender_beginn");
        var cfgEnd   = await Config.GetAsync("kalender_ende");
        _calStart = int.TryParse(cfgStart, out var cs) ? cs : 7;
        _calEnd   = int.TryParse(cfgEnd,   out var ce) ? ce : 23;

        // Bestehende Selektion aus Slot-Zeiten initialisieren
        _editSelStart = -1;
        _editSelEnd   = -1;
        _editConflict = false;
        _calInitializedForSlotId = null;
        _dotNetRef ??= DotNetObjectReference.Create(this);
        var stMin = startLocal.Hour * 60 + startLocal.Minute;
        var etMin = endLocal.Hour * 60 + endLocal.Minute;
        var slotCount = (_calEnd - _calStart) * 2;
        var selStart = (stMin - _calStart * 60) / 30;
        var selEnd   = (etMin - _calStart * 60) / 30 - 1;
        if (selStart >= 0 && selStart < slotCount && selEnd >= selStart && selEnd < slotCount)
        {
            _editSelStart = selStart;
            _editSelEnd   = selEnd;
        }

        // Bestehende Buchungen für diesen Tag laden
        await LoadCalendarSlotsAsync();
        CheckConflicts();
        _editLoading = false;
    }

    private void CancelEdit()
    {
        _editSlotId = null;
        _calInitializedForSlotId = null;
        _editSelStart = -1;
        _editSelEnd   = -1;
        _editConflict = false;
    }

    private async Task SaveEditAsync()
    {
        if (_editSlotId is null) return;
        if (_editConflict)
        {
            _error = "Der gewählte Zeitraum ist nicht verfügbar. Bitte einen anderen Zeitraum wählen.";
            return;
        }
        ClearMessages();
        try
        {
            var color = _editSlotType == SporthalleWeb.Domain.Reservierung.SlotType.Blocker
                ? "#78909C"
                : (string.IsNullOrWhiteSpace(_editColor) ? null : _editColor.Trim());
            await AdminService.UpdateSlotAsync(_editSlotId.Value,
                _editTitle.Trim(), color, string.IsNullOrWhiteSpace(_editNotes) ? null : _editNotes.Trim(),
                AdminUser);

            if (DateTime.TryParse(_editStartDate + "T" + _editStartTime, out var startLocal) &&
                DateTime.TryParse(_editEndDate   + "T" + _editEndTime,   out var endLocal))
            {
                var startUtc = TimeZoneInfo.ConvertTimeToUtc(startLocal, Zurich);
                var endUtc   = TimeZoneInfo.ConvertTimeToUtc(endLocal,   Zurich);
                await AdminService.RescheduleSlotAsync(_editSlotId.Value, startUtc, endUtc, AdminUser);
            }

            if (_editHasMember && _editMemberId.HasValue)
                await AdminService.UpdateMemberAsync(_editMemberId.Value,
                    _editContactPerson.Trim(),
                    string.IsNullOrWhiteSpace(_editPhone) ? null : _editPhone.Trim(),
                    _editRenterType,
                    _editBillingName.Trim(),
                    _editBillingAddress.Trim(),
                    _editBillingPostalCode.Trim(),
                    _editBillingCity.Trim(),
                    AdminUser);

            _message = "Buchung wurde gespeichert.";
            _editSlotId = null;
            await LoadPeriodAsync();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _error = ex.Message; }
    }

    private async Task ReactivateAsync(int slotId)
    {
        ClearMessages();
        try
        {
            await AdminService.ReactivateSlotAsync(slotId, AdminUser);
            _message = $"Buchung #{slotId} wurde reaktiviert.";
            await LoadPeriodAsync();
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex) { _error = ex.Message; }
    }

    private static DateOnly GetMonday(DateOnly date)
        => date.AddDays(-(((int)date.DayOfWeek + 6) % 7));

    private static int GetIsoWeek(DateTime date)
    {
        var cal = System.Globalization.CultureInfo.GetCultureInfo("de-CH").Calendar;
        return cal.GetWeekOfYear(date, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    }

    // ── Tageskalender-Logik ───────────────────────────────────────────────────

    public void Dispose() => _dotNetRef?.Dispose();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_editSlotId is not null && !_editLoading
            && _dotNetRef is not null
            && _calInitializedForSlotId != _editSlotId)
        {
            _calInitializedForSlotId = _editSlotId;
            await JS.InvokeVoidAsync("SporthalleAdmin.initEditCalendar",
                $"ec-{_editSlotId}", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnCalendarDragEnd(int startIdx, int endIdx)
    {
        _editSelStart = Math.Min(startIdx, endIdx);
        _editSelEnd   = Math.Max(startIdx, endIdx);
        SyncTimesFromSelection();
        CheckConflicts();
        await InvokeAsync(StateHasChanged);
    }

    private void SyncTimesFromSelection()
    {
        if (_editSelStart < 0 || _editSelEnd < 0) return;
        _editStartTime = SlotIdxToTime(_editSelStart);
        _editEndTime   = SlotIdxToTime(_editSelEnd + 1);
    }

    private string SlotIdxToTime(int idx)
    {
        var totalMin = _calStart * 60 + idx * 30;
        return $"{totalMin / 60:00}:{totalMin % 60:00}";
    }

    private void CheckConflicts()
    {
        if (_editSelStart < 0 || _editSelEnd < 0
            || !DateOnly.TryParse(_editStartDate, out var day))
        {
            _editConflict = false;
            return;
        }
        var selStartUtc = SlotIdxToUtc(day, _editSelStart);
        var selEndUtc   = SlotIdxToUtc(day, _editSelEnd + 1);
        _editConflict = _calendarSlotsForDay.Any(s =>
            s.Id != _editSlotId &&
            s.Slot.StartUtc < selEndUtc &&
            s.Slot.EndUtc   > selStartUtc);
    }

    private DateTime SlotIdxToUtc(DateOnly day, int idx)
    {
        var totalMin = _calStart * 60 + idx * 30;
        var local = new DateTime(day.Year, day.Month, day.Day,
            totalMin / 60, totalMin % 60, 0, DateTimeKind.Unspecified);
        return TimeZoneInfo.ConvertTimeToUtc(local, Zurich);
    }

    private SporthalleWeb.Domain.Reservierung.BookingSlot? GetExistingBookingAtSlot(int idx)
    {
        if (!DateOnly.TryParse(_editStartDate, out var day)) return null;
        var startUtc = SlotIdxToUtc(day, idx);
        var endUtc   = SlotIdxToUtc(day, idx + 1);
        return _calendarSlotsForDay.FirstOrDefault(s =>
            s.Id != _editSlotId &&
            s.Slot.StartUtc < endUtc &&
            s.Slot.EndUtc   > startUtc);
    }

    private string GetSlotCssClass(bool inSel, SporthalleWeb.Domain.Reservierung.BookingSlot? other)
    {
        if (inSel && other is not null) return "ec-slot-conflict";
        if (inSel) return "ec-slot-selected";
        if (other is not null) return "ec-slot-booked";
        return "";
    }

    private async Task LoadCalendarSlotsAsync()
    {
        if (!DateOnly.TryParse(_editStartDate, out var day)) return;
        _calendarSlotsForDay = await AdminService.GetSlotsForPeriodAsync(day, day, includeRejected: false);
    }

    private async Task OnEditDayChangedAsync(ChangeEventArgs e)
    {
        _editStartDate = e.Value?.ToString() ?? _editStartDate;
        _editEndDate   = _editStartDate;
        await LoadCalendarSlotsAsync();
        CheckConflicts();
    }
}
