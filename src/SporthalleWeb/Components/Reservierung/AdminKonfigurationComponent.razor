@inject SporthalleWeb.Application.Reservierung.HallConfigService Config

@if (_loading)
{
    <p>Lade Konfiguration…</p>
}
else
{
    <form @onsubmit="SaveAsync" @onsubmit:preventDefault>
        <div class="row g-4">

            <!-- Kalender-Zeiten -->
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size:0.75rem;letter-spacing:.08em">
                    Kalender
                </h6>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Öffnungszeit (Beginn)</label>
                        <input type="number" class="form-control" @bind="_kalenderBeginn" min="0" max="23" />
                        <div class="form-text">Stunde (0–23), z.B. 7 für 07:00</div>
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Öffnungszeit (Ende)</label>
                        <input type="number" class="form-control" @bind="_kalenderEnde" min="1" max="24" />
                        <div class="form-text">Stunde (1–24), z.B. 23 für 23:00</div>
                    </div>
                </div>
            </div>

            <!-- Online-Buchungen -->
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size:0.75rem;letter-spacing:.08em">
                    Online-Buchungen
                </h6>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Vorlaufzeit (Tage)</label>
                        <input type="number" class="form-control" @bind="_vorlaufzeitTage" min="0" max="365" />
                        <div class="form-text">Mindestvorlauf in Tagen. Kürzere Anfragen verweisen auf E-Mail.</div>
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Maximaler Vorauszeitraum (Wochen)</label>
                        <input type="number" class="form-control" @bind="_maxWochenVoraus" min="1" max="104" />
                        <div class="form-text">Wie weit im Voraus können Online-Buchungen gemacht werden?</div>
                    </div>
                </div>
            </div>

            <!-- E-Mail Reservationsbestätigung -->
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size:0.75rem;letter-spacing:.08em">
                    E-Mail: Reservationsbestätigung (Angefragt)
                </h6>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label fw-semibold">Absender / Admin-Adresse</label>
                        <input type="email" class="form-control" @bind="_mailReservationAdresse"
                               placeholder="admin@sporthalle-sulzerallee.ch" />
                        <div class="form-text">Wird als CC oder Reply-To verwendet.</div>
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label fw-semibold">Mailtext an den Mieter</label>
                    <textarea class="form-control font-monospace" @bind="_mailReservationText" rows="6"
                              placeholder="Guten Tag {Name}, wir haben Ihre Anfrage erhalten…"></textarea>
                    <div class="form-text">Verfügbare Platzhalter: {Name}, {Anlass}, {Datum}, {Von}, {Bis}</div>
                </div>
            </div>

            <!-- E-Mail Buchungsbestätigung -->
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size:0.75rem;letter-spacing:.08em">
                    E-Mail: Buchungsbestätigung (Bestätigt)
                </h6>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label fw-semibold">Absender / Admin-Adresse</label>
                        <input type="email" class="form-control" @bind="_mailBestaetigungAdresse"
                               placeholder="admin@sporthalle-sulzerallee.ch" />
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label fw-semibold">Mailtext an den Mieter</label>
                    <textarea class="form-control font-monospace" @bind="_mailBestaetigungText" rows="6"
                              placeholder="Guten Tag {Name}, Ihre Buchung wurde bestätigt…"></textarea>
                    <div class="form-text">Verfügbare Platzhalter: {Name}, {Anlass}, {Datum}, {Von}, {Bis}</div>
                </div>
            </div>

        </div>

        @if (_saved)
        {
            <div class="alert alert-success mt-4">Konfiguration gespeichert.</div>
        }
        @if (_saveError is not null)
        {
            <div class="alert alert-danger mt-4">@_saveError</div>
        }

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Speichern</button>
        </div>
    </form>
}

@code {
    private bool _loading = true;
    private bool _saved;
    private string? _saveError;

    private int _kalenderBeginn = 7;
    private int _kalenderEnde = 23;
    private int _vorlaufzeitTage = 3;
    private int _maxWochenVoraus = 12;
    private string _mailReservationAdresse = "";
    private string _mailReservationText = "";
    private string _mailBestaetigungAdresse = "";
    private string _mailBestaetigungText = "";

    protected override async Task OnInitializedAsync()
    {
        var cfg = await Config.GetAllAsync();
        _kalenderBeginn         = Parse(cfg, "kalender_beginn", 7);
        _kalenderEnde           = Parse(cfg, "kalender_ende", 23);
        _vorlaufzeitTage        = Parse(cfg, "vorlaufzeit_tage", 3);
        _maxWochenVoraus        = Parse(cfg, "max_wochen_voraus", 12);
        _mailReservationAdresse = cfg.GetValueOrDefault("mail_reservation_adresse") ?? "";
        _mailReservationText    = cfg.GetValueOrDefault("mail_reservation_text") ?? "";
        _mailBestaetigungAdresse = cfg.GetValueOrDefault("mail_bestaetigung_adresse") ?? "";
        _mailBestaetigungText   = cfg.GetValueOrDefault("mail_bestaetigung_text") ?? "";
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saved = false;
        _saveError = null;
        try
        {
            await Config.SetManyAsync(new Dictionary<string, string?>
            {
                ["kalender_beginn"]           = _kalenderBeginn.ToString(),
                ["kalender_ende"]             = _kalenderEnde.ToString(),
                ["vorlaufzeit_tage"]          = _vorlaufzeitTage.ToString(),
                ["max_wochen_voraus"]         = _maxWochenVoraus.ToString(),
                ["mail_reservation_adresse"]  = _mailReservationAdresse.Trim(),
                ["mail_reservation_text"]     = _mailReservationText,
                ["mail_bestaetigung_adresse"] = _mailBestaetigungAdresse.Trim(),
                ["mail_bestaetigung_text"]    = _mailBestaetigungText,
            });
            _saved = true;
        }
        catch (Exception ex)
        {
            _saveError = "Fehler beim Speichern: " + ex.Message;
        }
    }

    private static int Parse(Dictionary<string, string?> cfg, string key, int fallback)
        => cfg.TryGetValue(key, out var v) && int.TryParse(v, out var i) ? i : fallback;
}
