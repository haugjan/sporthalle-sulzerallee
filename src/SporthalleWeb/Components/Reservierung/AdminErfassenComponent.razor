@using Microsoft.JSInterop
@using System.Text.Json
@inject IJSRuntime JS
@inject SporthalleWeb.Application.Reservierung.BookingAdminService AdminService
@inject SporthalleWeb.Application.Reservierung.CreateBookingUseCase CreateBooking
@inject SporthalleWeb.Domain.Reservierung.Ports.IMemberManagerPort Members
@implements IAsyncDisposable

<!-- Kalender (exakt gleich wie öffentliche Seite) -->
<div style="padding: 0.5rem 0 1rem;">

  <div class="week-nav" style="padding: 0 1.5rem;">
    <button id="prev-week" aria-label="Vorwoche">&#8249;</button>
    <span id="week-label"></span>
    <button id="next-week" aria-label="Nächste Woche">&#8250;</button>
  </div>

  <div class="reservierung-layout" style="padding: 0 1.5rem; gap: 1.5rem;">

    <div class="reservierung-cal-col">
      <div class="calendar-scroll-wrapper">
        <div id="calendar-grid"></div>
      </div>
      <div class="calendar-legend" style="margin-top: 0.75rem;">
        <div class="legend-item"><span class="legend-dot confirmed"></span> Bestätigt</div>
        <div class="legend-item"><span class="legend-dot provisional"></span> Angefragt</div>
        <div class="legend-item"><span class="legend-dot recurring"></span> Blocker</div>
        <div class="legend-item"><span class="legend-dot free"></span> Frei</div>
      </div>
    </div>

    <div class="reservierung-panel-col">
      <div class="slot-panel" id="slot-panel">

        <div id="slot-panel-hint">
          Zeitraum im Kalender aufziehen, um einen Termin zu erfassen.
        </div>

        <div id="slot-panel-detail" hidden>
          <h3>Ausgewählter Termin</h3>
          <p id="slot-date-label" class="slot-panel__date"></p>
          <p class="slot-panel__time-display" id="slot-time-display"></p>
          <p class="slot-panel__meta" id="slot-meta"></p>
          <button class="btn-buchen" id="admin-btn-erfassen">Slot erfassen</button>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- Admin-Buchungsmodal -->
<div class="bm-overlay" id="admin-booking-modal" hidden aria-modal="true" role="dialog">
  <div class="bm-card">

    <div class="bm-header">
      <span class="bm-title" id="admin-bm-title">Slot erfassen</span>
      <button class="bm-close" id="admin-bm-close" aria-label="Schliessen">&#x2715;</button>
    </div>

    <div class="bm-slot-summary" id="admin-bm-slot-summary"></div>

    <!-- Typ-Wahl -->
    <div style="display:flex; gap:0.75rem; padding: 0.75rem 1.5rem; border-bottom: 1px solid #eee;">
      <button id="admin-typ-blocker" class="bm-btn-primary" style="flex:1; font-size:0.95rem;">Blocker</button>
      <button id="admin-typ-event" class="bm-btn-secondary" style="flex:1; font-size:0.95rem;">Buchungsanfrage</button>
    </div>

    <!-- Blocker-Formular -->
    <div id="admin-bm-body-blocker">
      <div class="bm-body">
        <div class="bm-form">
          <div class="bm-field bm-field--2col">
            <label>Bezeichnung *
              <input type="text" id="admin-bm-titel" placeholder="z.B. Hallenpflege, Wartung, Internes Training" />
            </label>
          </div>
          <div class="bm-field bm-field--2col">
            <label>Farbe
              <span style="display:flex;align-items:center;gap:0.5rem;margin-top:0.3rem">
                <span style="width:22px;height:22px;border-radius:4px;background:#37474f;display:inline-block;border:2px solid #333"></span>
                <span style="font-size:0.85rem;color:#555;font-weight:400;text-transform:none;letter-spacing:0">Immer Anthrazit</span>
              </span>
            </label>
          </div>
          <div class="bm-field bm-field--2col">
            <label>Bemerkungen (optional)
              <textarea id="admin-bm-notizen-blocker" rows="2" placeholder="Interne Notiz"></textarea>
            </label>
          </div>
          <div id="admin-bm-error-blocker" class="bm-error" hidden></div>
        </div>
      </div>
      <div class="bm-footer">
        <button class="bm-btn-secondary" id="admin-bm-cancel">Abbrechen</button>
        <button class="bm-btn-primary" id="admin-bm-submit-blocker">Blocker speichern</button>
      </div>
    </div>

    <!-- Buchungsanfrage-Formular (gleich wie extern) -->
    <div id="admin-bm-body-event" hidden>
      <div class="bm-body">
        <div class="bm-form">

          <div class="bm-field bm-field--2col">
            <label>Anlass *
              <input type="text" id="admin-bm-anlass" placeholder="z.B. Unihockeytraining, Plauschturnier, Gymnastik" />
            </label>
          </div>

          <div class="bm-field bm-field--2col">
            <label>Mietertyp *
              <select id="admin-bm-renter-type">
                <option value="Privatperson">Privatperson</option>
                <option value="Verein">Verein</option>
                <option value="Firma">Firma</option>
                <option value="Behörde">Behörde</option>
              </select>
            </label>
          </div>

          <div class="bm-field bm-field--2col" id="admin-bm-org-row" hidden>
            <label><span id="admin-bm-org-label">Vereinsname</span> *
              <input type="text" id="admin-bm-org-name" autocomplete="organization" />
            </label>
          </div>

          <div class="bm-field">
            <label>Vorname *
              <input type="text" id="admin-bm-firstname" autocomplete="given-name" placeholder="Vorname" />
            </label>
          </div>
          <div class="bm-field">
            <label>Nachname *
              <input type="text" id="admin-bm-lastname" autocomplete="family-name" placeholder="Nachname" />
            </label>
          </div>

          <div class="bm-field">
            <label>E-Mail *
              <input type="email" id="admin-bm-email" autocomplete="email" placeholder="name@beispiel.ch" />
            </label>
          </div>
          <div class="bm-field">
            <label>Handynummer
              <input type="tel" id="admin-bm-phone" autocomplete="tel" placeholder="+41 79 000 00 00" />
            </label>
          </div>

          <div class="bm-field bm-field--2col">
            <label>Farbe
              <div id="admin-bm-color-picker" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:0.3rem">
                <button type="button" class="bm-color-swatch bm-color-swatch--active" data-color="#F1C40F" style="background:#F1C40F" title="#F1C40F"></button>
                <button type="button" class="bm-color-swatch" data-color="#C0392B" style="background:#C0392B" title="#C0392B"></button>
                <button type="button" class="bm-color-swatch" data-color="#1F4E79" style="background:#1F4E79" title="#1F4E79"></button>
                <button type="button" class="bm-color-swatch" data-color="#2B4C7E" style="background:#2B4C7E" title="#2B4C7E"></button>
                <button type="button" class="bm-color-swatch" data-color="#1E5E4A" style="background:#1E5E4A" title="#1E5E4A"></button>
                <button type="button" class="bm-color-swatch" data-color="#4A5568" style="background:#4A5568" title="#4A5568"></button>
                <button type="button" class="bm-color-swatch" data-color="#8C3A5C" style="background:#8C3A5C" title="#8C3A5C"></button>
                <button type="button" class="bm-color-swatch" data-color="#A8522A" style="background:#A8522A" title="#A8522A"></button>
                <button type="button" class="bm-color-swatch" data-color="#4A3762" style="background:#4A3762" title="#4A3762"></button>
                <button type="button" class="bm-color-swatch" data-color="#1A5A66" style="background:#1A5A66" title="#1A5A66"></button>
                <button type="button" class="bm-color-swatch" data-color="#3A563C" style="background:#3A563C" title="#3A563C"></button>
                <button type="button" class="bm-color-swatch" data-color="#5C4033" style="background:#5C4033" title="#5C4033"></button>
              </div>
            </label>
          </div>

          <div class="bm-field bm-field--2col">
            <label>Bemerkungen
              <textarea id="admin-bm-notizen" rows="2" placeholder="Weitere Angaben (optional)"></textarea>
            </label>
          </div>

          <div id="admin-bm-error" class="bm-error" hidden></div>
        </div>
      </div>
      <div class="bm-footer">
        <button class="bm-btn-secondary" id="admin-bm-cancel2">Abbrechen</button>
        <button class="bm-btn-primary" id="admin-bm-submit">Buchungsanfrage erstellen</button>
      </div>
    </div>

    <!-- Erfolgsmeldung -->
    <div class="bm-success" id="admin-bm-success" hidden>
      <div class="bm-success-icon">&#x2713;</div>
      <h3 id="admin-bm-success-title">Gespeichert!</h3>
      <p id="admin-bm-success-msg"></p>
      <button class="bm-btn-primary" id="admin-bm-done">Fertig</button>
    </div>

  </div>
</div>

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";

    private DotNetObjectReference<AdminErfassenComponent>? _objRef;

    protected override void OnInitialized()
    {
        _objRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("SporthalleAdmin.initKalender", _objRef);
    }

    [JSInvokable]
    public async Task<string> GetWochenSlotsAsync(string von)
    {
        var monday = DateOnly.Parse(von);
        var items = await AdminService.GetWeekSlotsWithMembersAsync(monday);
        var dto = items.Select(x => new
        {
            type       = x.Slot.Type.ToString(),
            startUtc   = x.Slot.Slot.StartUtc.ToString("o"),
            endUtc     = x.Slot.Slot.EndUtc.ToString("o"),
            title      = x.Slot.Title,
            color      = x.Slot.Color,
            mieterName = x.Member?.ContactPerson
        });
        return JsonSerializer.Serialize(dto);
    }

    [JSInvokable]
    public async Task<string> BuchungAnlegenAsync(string payloadJson)
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var payload = JsonSerializer.Deserialize<AdminBuchungPayload>(payloadJson, opts);
            if (payload is null)
                return Err("Ungültige Daten.");

            var startUtc = ParseUtc(payload.StartUtc);
            var endUtc   = ParseUtc(payload.EndUtc);

            if (payload.IsBlocker)
            {
                if (string.IsNullOrWhiteSpace(payload.Titel))
                    return Err("Bezeichnung ist erforderlich.");

                await AdminService.CreateSlotAsync(
                    SporthalleWeb.Domain.Reservierung.SlotType.Blocker,
                    startUtc, endUtc,
                    payload.Titel.Trim(), "#37474f",
                    string.IsNullOrWhiteSpace(payload.Notizen) ? null : payload.Notizen.Trim(),
                    null, AdminUser);

                return Ok(true);
            }

            // Buchungsanfrage: Mitglied suchen oder anlegen
            var existing = await Members.FindByEmailAsync(payload.Email!.Trim());
            int memberId;
            if (existing is not null)
            {
                memberId = existing.Id;
            }
            else
            {
                var contactPerson = $"{payload.Firstname} {payload.Lastname}".Trim();
                var billingName   = string.IsNullOrWhiteSpace(payload.OrgName) ? contactPerson : payload.OrgName!.Trim();
                var cmd = new SporthalleWeb.Application.Reservierung.RegisterRenterCommand(
                    Email:             payload.Email.Trim(),
                    ContactPerson:     contactPerson,
                    RenterType:        new SporthalleWeb.Domain.Reservierung.RenterType(payload.RenterType ?? "Privatperson"),
                    BillingName:       billingName,
                    BillingAddress:    "",
                    BillingPostalCode: "",
                    BillingCity:       "",
                    BillingCountry:    "CH",
                    Phone:             string.IsNullOrWhiteSpace(payload.Phone) ? null : payload.Phone!.Trim(),
                    HasKey:            false,
                    Password:          null);
                var member = await Members.CreateAsync(cmd, null);
                memberId = member.Id;
            }

            var bookCmd = new SporthalleWeb.Application.Reservierung.CreateBookingCommand(
                memberId, startUtc, endUtc,
                payload.Anlass ?? "Buchung",
                string.IsNullOrWhiteSpace(payload.Notizen) ? null : payload.Notizen!.Trim(),
                string.IsNullOrWhiteSpace(payload.Color) ? null : payload.Color!.Trim());
            await CreateBooking.ExecuteAsync(bookCmd);

            return Ok(false);
        }
        catch (SporthalleWeb.Domain.Reservierung.SlotConflictException)
        {
            return Err("Dieser Zeitslot ist nicht mehr verfügbar. Bitte einen anderen Termin wählen.");
        }
        catch (SporthalleWeb.Domain.Reservierung.DomainException ex)
        {
            return Err(ex.Message);
        }
        catch (Exception ex)
        {
            return Err("Unerwarteter Fehler: " + ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("SporthalleAdmin.destroyKalender"); } catch { /* component gone */ }
        _objRef?.Dispose();
    }

    private static DateTime ParseUtc(string? iso) =>
        DateTime.Parse(iso!, null, System.Globalization.DateTimeStyles.RoundtripKind);

    private static string Ok(bool isBlocker) =>
        JsonSerializer.Serialize(new { ok = true, isBlocker });

    private static string Err(string message) =>
        JsonSerializer.Serialize(new { ok = false, error = message });

    private sealed class AdminBuchungPayload
    {
        public bool IsBlocker { get; set; }
        public string? StartUtc { get; set; }
        public string? EndUtc { get; set; }
        public string? Titel { get; set; }
        public string? Anlass { get; set; }
        public string? Color { get; set; }
        public string? Notizen { get; set; }
        public string? RenterType { get; set; }
        public string? OrgName { get; set; }
        public string? Firstname { get; set; }
        public string? Lastname { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
    }
}
