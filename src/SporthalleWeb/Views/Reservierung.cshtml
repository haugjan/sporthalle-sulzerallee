@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
  Layout = "~/Views/Shared/_SiteLayout.cshtml";
  var heading   = Model.Value<string>("pageHeading") ?? Model.Name;
  var imageUrl  = Model.Value<string>("pageImage");
  var introText = Model.Value<string>("introText");
  var textAfter = Model.Value<string>("textAfter");
  var hasImage  = !string.IsNullOrWhiteSpace(imageUrl);
  ViewBag.PageTitle = heading + " – Sporthalle Sulzerallee";
  ViewBag.TransparentNav = hasImage;

  var sessionConfirmed = Context.Request.Query["session"] == "confirmed";
  var tokenError = Context.Request.Query["error"] == "invalid-token";
}

@section Head {
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/reservierung.css" />
}

@if (hasImage)
{
  <div class="page-header">
    <div class="page-header-bg" style="background-image:url('@imageUrl')"></div>
    <div class="page-header-fade"></div>
    <div class="page-header-body">
      <h1 class="page-header-title">@heading</h1>
    </div>
  </div>
}

<div class="reservierung-outer" style="@(hasImage ? "" : "padding-top:68px;")">

  @if (!hasImage)
  {
    <div style="max-width:1280px;margin:0 auto;padding:3rem 2.5rem 2rem;">
      <h1 style="font-family:'Anton',Impact,sans-serif;font-size:clamp(3rem,8vw,6rem);line-height:0.85;letter-spacing:0.02em;text-transform:uppercase;">@heading</h1>
      <div style="width:3rem;height:3px;background:var(--dust,#eb504b);margin-top:0.75rem;"></div>
    </div>
  }

  @if (sessionConfirmed)
  {
    <div class="session-alert session-alert--success">Du bist jetzt angemeldet!</div>
  }
  @if (tokenError)
  {
    <div class="session-alert session-alert--error">Der Anmelde-Link ist ungültig oder abgelaufen. Bitte fordere einen neuen an.</div>
  }

  @if (!string.IsNullOrWhiteSpace(introText))
  {
    <div class="reservierung-intro">
      <p>@introText</p>
    </div>
  }

  <div class="reservierung-section">
    <div class="reservierung-layout">

      <!-- Kalender -->
      <div class="reservierung-cal-col">
        <div class="week-nav">
          <button type="button" id="prev-week" aria-label="Vorwoche">&#8249;</button>
          <div class="week-nav-center">
            <span id="week-label"></span>
            <button type="button" id="dp-toggle" class="dp-toggle-btn" aria-label="Datum wählen" title="Zu Datum springen">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
            </button>
            <div id="date-picker" class="dp-popup"></div>
          </div>
          <button type="button" id="next-week" aria-label="Nächste Woche">&#8250;</button>
        </div>
        <div class="calendar-scroll-wrapper">
          <div id="calendar-grid"></div>
        </div>
        <div class="calendar-legend">
          <div class="legend-item"><span class="legend-dot confirmed"></span> Belegt</div>
          <div class="legend-item"><span class="legend-dot provisional"></span> Angefragt</div>
          <div class="legend-item"><span class="legend-dot free"></span> Frei</div>
        </div>
      </div>

      <!-- Slot-Panel + Preise -->
      <div class="reservierung-panel-col">
        <div class="slot-panel" id="slot-panel">

          <div id="slot-panel-hint">
            Zeitraum im Kalender aufziehen, um einen Termin zu wählen.
          </div>

          <div id="slot-panel-detail" hidden>
            <h3>Ausgewählter Termin</h3>
            <p id="slot-date-label" class="slot-panel__date"></p>
            <div class="slot-panel__times">
              <div class="slot-panel__time-item">
                <span class="slot-panel__time-label">Von</span>
                <span class="slot-panel__time-val" id="slot-von">–</span>
              </div>
              <span class="slot-panel__time-dash">bis</span>
              <div class="slot-panel__time-item">
                <span class="slot-panel__time-label">Bis</span>
                <span class="slot-panel__time-val" id="slot-bis">–</span>
              </div>
            </div>
            <div class="slot-panel__notice slot-panel__notice--warn" id="slot-short-notice" hidden>
              <p id="slot-short-notice-text">Für Reservationen mit zu kurzem Vorlauf bitte direkt per E-Mail melden:</p>
              <a href="mailto:reservation@sporthalle-sulzerallee.ch">reservation@sporthalle-sulzerallee.ch</a>
            </div>
            <div class="slot-panel__notice slot-panel__notice--warn" id="slot-beyond-cutoff" hidden>
              <p>Für Reservationen weit im Voraus bitte direkt per E-Mail melden:</p>
              <a href="mailto:reservation@sporthalle-sulzerallee.ch">reservation@sporthalle-sulzerallee.ch</a>
            </div>
            <button class="btn-buchen" id="btn-jetzt-buchen">Jetzt buchen</button>
          </div>

        </div>

        <div class="preis-panel" id="preis-panel" hidden>
          <h4>Preise</h4>
          <p id="preis-panel-text"></p>
        </div>
      </div>

    </div>
  </div>

  @if (!string.IsNullOrWhiteSpace(textAfter))
  {
    <div class="reservierung-intro reservierung-after">
      <p>@textAfter</p>
    </div>
  }

  <!-- Buchungs-Modal -->
  <div class="bm-overlay" id="booking-modal" hidden aria-modal="true" role="dialog" aria-labelledby="bm-title-text">
    <div class="bm-card">

      <div class="bm-header">
        <span class="bm-title" id="bm-title-text">Buchung abschliessen</span>
        <button class="bm-close" id="bm-close" aria-label="Schliessen">&#x2715;</button>
      </div>

      <div class="bm-slot-summary" id="bm-slot-summary"></div>

      <div class="bm-body" id="bm-body">
        <h3>Deine Angaben</h3>
        <div class="bm-form">

          <!-- 1. Anlass -->
          <div class="bm-field bm-field--2col">
            <label>Anlass *
              <input type="text" id="bm-anlass" placeholder="z.B. Unihockeytraining, Plauschturnier, Gymnastik" />
            </label>
          </div>

          <!-- 2. Mietertyp -->
          <div class="bm-field bm-field--2col">
            <label>Mietertyp *
              <select id="bm-renter-type">
                <option value="Privatperson">Privatperson</option>
                <option value="Verein">Verein</option>
                <option value="Firma">Firma</option>
                <option value="Behörde">Behörde</option>
              </select>
            </label>
          </div>

          <!-- 3. Organisationsname (nur für Verein / Firma / Behörde) -->
          <div class="bm-field bm-field--2col" id="bm-org-row" hidden>
            <label><span id="bm-org-label">Vereinsname</span> *
              <input type="text" id="bm-org-name" autocomplete="organization" />
            </label>
          </div>

          <!-- 4. Vorname / Nachname -->
          <div class="bm-field">
            <label><span class="bm-label-row"><span id="bm-firstname-label">Vorname</span> *</span>
              <input type="text" id="bm-firstname" autocomplete="given-name" placeholder="Vorname" />
            </label>
          </div>
          <div class="bm-field">
            <label><span class="bm-label-row"><span id="bm-lastname-label">Nachname</span> *</span>
              <input type="text" id="bm-lastname" autocomplete="family-name" placeholder="Nachname" />
            </label>
          </div>

          <!-- 5. Mobilnummer / E-Mail -->
          <div class="bm-field">
            <label>Mobilnummer *
              <input type="tel" id="bm-phone" autocomplete="tel" placeholder="+41 79 000 00 00" />
            </label>
            <small class="bm-field-hint">erreichbar während des Events</small>
          </div>
          <div class="bm-field">
            <label>E-Mail *
              <input type="email" id="bm-email" autocomplete="email" placeholder="name@beispiel.ch" />
            </label>
          </div>

          <!-- 6. Adresse -->
          <div class="bm-field bm-field--2col">
            <label>Strasse *
              <input type="text" id="bm-billing-street" autocomplete="street-address" placeholder="Musterstrasse 1" />
            </label>
          </div>
          <div class="bm-field bm-field--2col">
            <label>Adresszusatz
              <input type="text" id="bm-billing-extra" autocomplete="address-line2" placeholder="c/o, Postfach, Stockwerk (optional)" />
            </label>
          </div>
          <div class="bm-field bm-field--plz">
            <label>PLZ *
              <input type="text" id="bm-billing-plz" autocomplete="postal-code" placeholder="8400" />
            </label>
            <label>Ort *
              <input type="text" id="bm-billing-city" autocomplete="address-level2" placeholder="Winterthur" />
            </label>
          </div>

          <!-- 7. Bemerkungen -->
          <div class="bm-field bm-field--2col">
            <label>Bemerkungen
              <textarea id="bm-notizen" rows="3" placeholder="Weitere Angaben (optional)"></textarea>
            </label>
          </div>

          <div id="bm-turnstile" class="bm-turnstile" data-sitekey="@(Config["Turnstile:SiteKey"] ?? "1x00000000000000000000AA")"></div>

          <div id="bm-error" class="bm-error" hidden></div>
        </div>
      </div>

      <div class="bm-footer" id="bm-footer">
        <button class="bm-btn-secondary" id="bm-cancel">Abbrechen</button>
        <button class="bm-btn-primary" id="bm-submit">Buchungsanfrage senden</button>
      </div>

      <div class="bm-success" id="bm-success" hidden>
        <div class="bm-success-icon">&#x2713;</div>
        <h3>Anfrage eingegangen!</h3>
        <p>Wir prüfen deinen Termin und melden uns per E-Mail bei dir.</p>
        <button class="bm-btn-primary" id="bm-done">Fertig</button>
      </div>

    </div>
  </div>

</div>

@section Scripts {
  <script src="/js/reservierung.js"></script>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
}