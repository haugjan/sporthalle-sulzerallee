@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
  Layout = "~/Views/Shared/_Layout.cshtml";
  var heading = Model.Value<string>("pageHeading") ?? Model.Name;
  var introText = Model.Value<string>("introText");
  ViewBag.Title = heading + " – Sporthalle Sulzerallee";
}

@section Styles {
  <link rel="stylesheet" href="/css/reservierung.css" />
}

<div class="page-content">
  <div class="page-header">
    <h2>@heading</h2>
  </div>
  <div class="page-header-bar"></div>

  @if (!string.IsNullOrWhiteSpace(introText))
  {
    <section class="reservierung-intro">
      <p>@introText</p>
    </section>
  }

  <section class="reservierung-section">
    <div id="reservierung-app">
      <div class="week-nav">
        <button id="prev-week" aria-label="Vorherige Woche">&#8249;</button>
        <span id="week-label"></span>
        <button id="next-week" aria-label="Nächste Woche">&#8250;</button>
      </div>
      <div class="calendar-scroll-wrapper">
        <div id="calendar-grid"></div>
      </div>
      <div class="calendar-legend">
        <span class="legend-item"><span class="legend-dot confirmed"></span>Belegt</span>
        <span class="legend-item"><span class="legend-dot provisional"></span>Angefragt</span>
        <span class="legend-item"><span class="legend-dot recurring"></span>Dauerbelegung</span>
        <span class="legend-item"><span class="legend-dot free"></span>Frei</span>
      </div>
    </div>
  </section>
</div>

@section Scripts {
  <script src="/js/reservierung.js"></script>
}
