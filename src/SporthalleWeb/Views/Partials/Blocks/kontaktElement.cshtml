@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem>
@using System.Text.RegularExpressions
@functions {
    private static string ParseLinks(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        text = Regex.Replace(text, @"\[([^\]]+)\]\(([^)]+)\)",
            m => $"<a href=\"{m.Groups[2].Value}\" target=\"_blank\" rel=\"noopener\">{m.Groups[1].Value}</a>");
        text = Regex.Replace(text, @"(?<![""=>])([A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,})(?![^<]*>)",
            m => $"<a href=\"mailto:{m.Groups[1].Value}\">{m.Groups[1].Value}</a>");
        return text;
    }
}
@{
    var label       = Model.Content.Value<string>("label")       ?? "";
    var header      = Model.Content.Value<string>("header")      ?? "";
    var introHeader = Model.Content.Value<string>("introHeader") ?? "";
    var intro       = Model.Content.Value<string>("intro")       ?? "";
    var factsRaw    = Model.Content.Value<string>("facts")       ?? "";
    var bildObj     = Model.Content.GetProperty("bild")?.GetValue() as IPublishedContent;
    var bildUrl     = bildObj?.GetCropUrl() ?? "";
    var hasBild     = !string.IsNullOrEmpty(bildUrl);

    var factBlocks = factsRaw
        .Split(new[] { "\r\n\r\n", "\n\n" }, StringSplitOptions.RemoveEmptyEntries);

    var facts = factBlocks
        .Select(block => {
            var lines = block.Split(new[] { "\r\n", "\n" }, StringSplitOptions.None);
            var fLabel = lines.Length > 0 ? lines[0].Trim() : "";
            var fValue = lines.Length > 1 ? string.Join("\n", lines.Skip(1)).Trim() : "";
            return (fLabel, fValue);
        })
        .Where(f => !string.IsNullOrWhiteSpace(f.fLabel) || !string.IsNullOrWhiteSpace(f.fValue))
        .ToArray();
}
<section class="ke-section">
  <div class="ke-container">
    <div class="ke-outer-grid @(hasBild ? "ke-outer-grid--with-image" : "")">

      <div class="ke-content">
        @if (!string.IsNullOrEmpty(label))
        {
          <span class="ke-label">@label</span>
        }
        @if (!string.IsNullOrEmpty(header))
        {
          <h2 class="ke-heading">@Html.Raw(header.Replace("\n", "<br/>"))</h2>
        }

        @if (!string.IsNullOrEmpty(introHeader) || !string.IsNullOrEmpty(intro))
        {
          <div class="ke-intro-block">
            @if (!string.IsNullOrEmpty(introHeader))
            {
              <strong class="ke-intro-header">@introHeader</strong>
            }
            @if (!string.IsNullOrEmpty(intro))
            {
              <p class="ke-intro-text">@Html.Raw(ParseLinks(intro).Replace("\n", "<br/>"))</p>
            }
          </div>
        }

        @if (facts.Length > 0)
        {
          <div class="ke-pairs">
            @foreach (var (fLabel, fValue) in facts)
            {
              <div class="ke-pair">
                <hr class="ke-rule" />
                @if (!string.IsNullOrEmpty(fLabel))
                {
                  <span class="ke-pair-label">@fLabel</span>
                }
                @if (!string.IsNullOrEmpty(fValue))
                {
                  <p class="ke-pair-value">@Html.Raw(ParseLinks(fValue).Replace("\n", "<br/>"))</p>
                }
              </div>
            }
            <hr class="ke-rule" />
          </div>
        }
      </div>

      @if (hasBild)
      {
        <div class="ke-image-col">
          <img src="@bildUrl" alt="" class="ke-image" />
        </div>
      }

    </div>
  </div>
</section>
