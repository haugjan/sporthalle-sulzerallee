@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var configKey = Configuration["Turnstile:SiteKey"];
    var turnstileSiteKey = ViewData["TurnstileSiteKey"] as string
        ?? (string.IsNullOrEmpty(configKey) ? null : configKey)
        ?? "1x00000000000000000000AA";
}

<div class="pm-stufen-section">
  <div class="pm-stufen">
    <div class="pm-stufe pm-stufe--bronze">
      <span class="pm-stufe__badge">Bronze</span>
      <p class="pm-stufe__name">Hallenbodenbesitzer</p>
      <p class="pm-stufe__price">CHF 50.– <span>/Jahr</span></p>
      <ul class="pm-stufe__benefits">
        <li>Ein Stück Hallenboden symbolisch</li>
        <li>Newsletter</li>
      </ul>
    </div>
    <div class="pm-stufe pm-stufe--silber">
      <span class="pm-stufe__badge">Silber</span>
      <p class="pm-stufe__name">Chnebler</p>
      <p class="pm-stufe__price">CHF 100.– <span>/Jahr</span></p>
      <ul class="pm-stufe__benefits">
        <li>Ein Stück Hallenboden symbolisch</li>
        <li>Zugang offene Sonntage (Familie)</li>
        <li>Newsletter</li>
      </ul>
    </div>
    <div class="pm-stufe pm-stufe--gold">
      <span class="pm-stufe__badge">Gold</span>
      <p class="pm-stufe__name">Cüpli-Chnebler</p>
      <p class="pm-stufe__price">CHF 200.– <span>/Jahr</span></p>
      <ul class="pm-stufe__benefits">
        <li>Ein Stück Hallenboden symbolisch</li>
        <li>Zugang offene Sonntage (Familie)</li>
        <li>Jährlicher Sponsor-Event</li>
        <li>Newsletter</li>
      </ul>
    </div>
  </div>
</div>

<iframe src="/passivmitglieder/hallenboden"
        style="width:100%;border:none;display:block;min-height:700px;"
        id="pm-hallenboden-frame"
        title="Hallenboden Passivmitgliedschaft"></iframe>

@* legacy – no longer used, kept until iframe is verified *@
