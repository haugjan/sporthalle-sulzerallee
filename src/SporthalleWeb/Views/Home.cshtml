@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using System.Linq
@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.PropertyEditors.ValueConverters
@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";
    ViewBag.TransparentNav = true;
    ViewBag.PageTitle = "Sporthalle Sulzerallee — Winterthur";

    var blocks = Model.Value<BlockListModel>("content") ?? new BlockListModel(new List<BlockListItem>());
    var heroBlock   = blocks.FirstOrDefault(b => b.Content.ContentType.Alias == "heroElement");
    var festBlock   = blocks.FirstOrDefault(b => b.Content.ContentType.Alias == "festElement");
    var teaserBlocks = blocks.Where(b => b.Content.ContentType.Alias == "teaserElement").ToList();

    // Hero values – MediaPicker3 single-pick returns MediaWithCrops<Image>, not IEnumerable
    var heroMediaObj  = heroBlock?.Content.GetProperty("heroImage")?.GetValue() as IPublishedContent;
    var heroImage     = heroMediaObj?.GetCropUrl() ?? "";
    var heroLogoObj   = heroBlock?.Content.GetProperty("logoSvg")?.GetValue() as IPublishedContent;
    var heroLogoUrl   = heroLogoObj?.GetCropUrl() ?? "";
    var schlagwoerter = (heroBlock?.Content.Value<string>("schlagwoerter") ?? "Winterthur,Schulen,Unihockey")
                         .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    // Fest values
    var festLabel = festBlock?.Content.Value<string>("label") ?? "";
    var festTitel = festBlock?.Content.Value<string>("titel") ?? "";
    var festDatum = festBlock?.Content.Value<string>("datum") ?? "";
    var festText  = festBlock?.Content.Value<string>("text")  ?? "";
}
@section Head {
  <link rel="stylesheet" href="/css/elements/hero-element.css" />
  <link rel="stylesheet" href="/css/elements/fest-element.css" />
  <link rel="stylesheet" href="/css/elements/teaser-element.css" />
}

<!-- HERO -->
<section class="hero">
  @if (!string.IsNullOrEmpty(heroImage))
  {
    <div class="hero-bg" style="background-image:url('@heroImage');"></div>
  }
  @if (!string.IsNullOrEmpty(heroLogoUrl))
  {
    <img class="hero-logo" src="@heroLogoUrl" alt="Sporthalle Sulzerallee" />
  }
  else
  {
    <div class="hero-wordmark" aria-hidden="true">
      <div>
        <span class="hero-word hero-word--l">SPORT</span>
        <span class="hero-word hero-word--l">HALLE</span>
      </div>
      <div>
        <span class="hero-word hero-word--r">SULZER</span>
        <span class="hero-word hero-word--r">ALLEE</span>
      </div>
    </div>
  }
  <div class="hero-bar">
    @foreach (var tag in schlagwoerter)
    {
      <span class="hero-tag">@tag</span>
    }
    <div class="hero-bar-scroll">
      <span>Scroll</span>
      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 1.5v10M2.5 8l4 4 4-4"/></svg>
    </div>
  </div>
</section>

<!-- ERÖFFNUNGSFEST -->
@if (festBlock != null && !string.IsNullOrEmpty(festTitel))
{
  <section class="fest-section dust-grain">
    <div class="container">
      <div>
        @if (!string.IsNullOrEmpty(festLabel))
        {
          <span class="t-label fest-label">@festLabel</span>
        }
        <h2 class="fest-title">@Html.Raw(festTitel.Replace("\n", "<br />"))</h2>
        @if (!string.IsNullOrEmpty(festDatum))
        {
          <p class="fest-date">@festDatum</p>
        }
        @if (!string.IsNullOrEmpty(festText))
        {
          <p class="fest-text">@festText</p>
        }
      </div>
    </div>
  </section>
}

<!-- TEASERS -->
@if (teaserBlocks.Count > 0)
{
  <section>
    <div class="teasers-grid">
      @for (int i = 0; i < teaserBlocks.Count; i++)
      {
        var tb      = teaserBlocks[i];
        var tLabel  = tb.Content.Value<string>("label") ?? "";
        var tTitel  = tb.Content.Value<string>("titel") ?? "";
        var tText   = tb.Content.Value<string>("text")  ?? "";
        var tLink   = tb.Content.Value<IEnumerable<Link>>("link")?.FirstOrDefault()?.Url ?? "#";
        var tBild   = (tb.Content.GetProperty("bild")?.GetValue() as IPublishedContent)?.GetCropUrl() ?? "";
        var tNum    = (i + 1).ToString("D2");

        var tCls = i % 2 == 0 ? "teaser--white" : "teaser--dust";
        var tCta = i == 1 ? "Jetzt Mitglied werden" : i == 2 ? "Jetzt buchen" : "Mehr erfahren";
        <a href="@tLink" class="teaser @tCls">
          <div class="teaser-deco">@tNum</div>
          <div class="teaser-body">
            @if (!string.IsNullOrEmpty(tLabel)) { <span class="t-label">@tLabel</span> }
            <span class="teaser-title">@Html.Raw(tTitel.Replace("\n", "<br />"))</span>
            @if (!string.IsNullOrEmpty(tText)) { <span class="teaser-sub">@tText</span> }
            <span class="link-arrow">@tCta <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6.5h9M7 2.5l4 4-4 4"/></svg></span>
          </div>
        </a>
      }
    </div>
  </section>
}