@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="icon" href="/fav.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/css/sporthalle.css" />
  @RenderSection("Head", required: false)
  @RenderSection("Styles", required: false)
  <title>@ViewBag.Title</title>
</head>
<body class="@ViewBag.BodyClass">
  <header>
    <nav>
      @{
        var root = Umbraco.ContentAtRoot()?.FirstOrDefault();
        var navItems = root?.Children() ?? Enumerable.Empty<IPublishedContent>();
      }
      <div class="logo">
        <a href="/"><img src="/img/sporthalle_sulzerallee_logo_neu.png" alt="Sporthalle Sulzerallee Logo" /></a>
      </div>
      <div class="menu-toggle" id="menu-toggle">☰</div>
      <ul class="nav-links" id="nav-links">
        @foreach (var item in navItems)
        {
          var isActive = ViewContext.HttpContext.Request.Path.Value?.TrimEnd('/').Equals(item.Url()?.TrimEnd('/'), StringComparison.OrdinalIgnoreCase) ?? false;
          <li><a href="@item.Url()" class="@(isActive ? "active" : "")">@item.Name</a></li>
        }
      </ul>
      <a href="/umbraco" class="nav-admin-link" title="Verwaltung" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </a>
    </nav>
  </header>

  @RenderBody()

  <footer>
    &copy; 2025 Sporthalle Sulzerallee. Alle Rechte vorbehalten.
  </footer>

  <script src="/js/sporthalle.js"></script>
  @RenderSection("Scripts", required: false)
  <script src="_framework/blazor.server.js"></script>
</body>
</html>
