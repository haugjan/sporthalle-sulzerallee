@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var error = ViewBag.Error as string;
}

<div class="page-content content-narrow" style="max-width:560px;margin:2rem auto">
    <h2>Registrieren</h2>
    <p class="text-muted">Nach der Registrierung erhältst du einen Anmelde-Link per E-Mail.</p>

    @if (error is not null)
    {
        <div class="alert alert-danger">@error</div>
    }

    <form method="post" action="/reservierung/registrieren">
        @Html.AntiForgeryToken()
        <div class="card p-4">
            <h5 class="mb-3">Kontaktangaben</h5>
            <div class="mb-3">
                <label class="form-label">E-Mail-Adresse *</label>
                <input type="email" name="email" class="form-control" required autocomplete="email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Mietertyp *</label>
                <select name="renterType" class="form-select" required id="reg-renter-type">
                    <option value="Privatperson">Privatperson</option>
                    <option value="Verein">Verein</option>
                    <option value="Firma">Firma / Unternehmen</option>
                    <option value="Behörde">Behörde</option>
                </select>
            </div>
            <div class="mb-3" id="reg-name-row" style="display:none">
                <label class="form-label" id="reg-name-label">Organisationsname *</label>
                <input type="text" name="name" id="reg-name" class="form-control" autocomplete="organization" />
            </div>
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="form-label">Vorname *</label>
                    <input type="text" name="contactFirstName" class="form-control" required autocomplete="given-name" />
                </div>
                <div class="col-6">
                    <label class="form-label">Nachname *</label>
                    <input type="text" name="contactLastName" class="form-control" required autocomplete="family-name" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Telefon (optional)</label>
                <input type="tel" name="phone" class="form-control" autocomplete="tel" />
            </div>
        </div>

        <div class="card p-4 mt-3">
            <h5 class="mb-3">Rechnungsadresse</h5>
            <div class="mb-3">
                <label class="form-label">Strasse und Hausnummer *</label>
                <input type="text" name="billingAddress" class="form-control" required autocomplete="street-address" />
            </div>
            <div class="mb-3">
                <label class="form-label">Adresszusatz (optional)</label>
                <input type="text" name="addressLine2" class="form-control" autocomplete="address-line2" />
            </div>
            <div class="row g-2">
                <div class="col-4">
                    <label class="form-label">PLZ *</label>
                    <input type="text" name="billingPostalCode" class="form-control" required autocomplete="postal-code" />
                </div>
                <div class="col-8">
                    <label class="form-label">Ort *</label>
                    <input type="text" name="billingCity" class="form-control" required autocomplete="address-level2" />
                </div>
            </div>
        </div>

        <div class="card p-4 mt-3">
            <h5 class="mb-3">Passwort (optional)</h5>
            <p class="text-muted small">Leer lassen für ausschliesslichen Magic-Link-Login.</p>
            <div class="mb-3">
                <label class="form-label">Passwort</label>
                <input type="password" name="password" class="form-control"
                       minlength="8" autocomplete="new-password"
                       placeholder="Mindestens 8 Zeichen" />
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary w-100">Registrieren</button>
        </div>
    </form>

    <p class="text-center text-muted mt-3">
        Bereits registriert?
        <a href="/reservierung/anmelden">Anmelden</a>
    </p>
</div>

<script>
(function () {
    var typeSelect = document.getElementById('reg-renter-type');
    var nameRow = document.getElementById('reg-name-row');
    var nameLabel = document.getElementById('reg-name-label');
    var nameInput = document.getElementById('reg-name');
    var labels = { 'Verein': 'Vereinsname *', 'Firma': 'Firmenname *', 'Behörde': 'Behördenname *' };
    function update() {
        var t = typeSelect.value;
        var isOrg = t !== 'Privatperson';
        nameRow.style.display = isOrg ? '' : 'none';
        nameInput.required = isOrg;
        if (isOrg && labels[t]) nameLabel.textContent = labels[t];
    }
    typeSelect.addEventListener('change', update);
    update();
})();
</script>
