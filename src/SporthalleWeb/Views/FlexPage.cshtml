@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models.Blocks
@{
    Layout = "~/Views/Shared/_SiteLayout.cshtml";
    ViewBag.PageTitle = Model.Name + " – Sporthalle Sulzerallee";
    var blocks = Model.Value<BlockListModel>("content")?.ToList() ?? new List<BlockListItem>();
    var aliases = blocks.Select(b => b.Content.ContentType.Alias).ToHashSet();
    var hasRes  = aliases.Contains("reservationElement");
    var hasBhe  = aliases.Contains("headerElement");
    ViewBag.TransparentNav = hasBhe;
}
@section Head {
    @if (hasRes)
    {
        <link rel="stylesheet" href="/css/reservierung.css?v=2" />
    }
}
<main class="flexpage-main" style="@(hasBhe ? "" : "padding-top:68px;")">
@{
    int idx = 0;
    while (idx < blocks.Count)
    {
        var block = blocks[idx];
        var alias = block.Content.ContentType.Alias;
        if (alias == "produktElement")
        {
            var group = new List<BlockListItem>();
            while (idx < blocks.Count && blocks[idx].Content.ContentType.Alias == "produktElement")
            {
                group.Add(blocks[idx]);
                idx++;
            }
            <div class="produkt-row">
                @foreach (var g in group)
                {
                    @await Html.PartialAsync("~/Views/Partials/Blocks/produktElement.cshtml", g)
                }
            </div>
        }
        else if (alias == "preisElement")
        {
            var group = new List<BlockListItem>();
            while (idx < blocks.Count && blocks[idx].Content.ContentType.Alias == "preisElement")
            {
                group.Add(blocks[idx]);
                idx++;
            }
            <div class="preis-row">
                @foreach (var g in group)
                {
                    @await Html.PartialAsync("~/Views/Partials/Blocks/preisElement.cshtml", g)
                }
            </div>
        }
        else if (alias == "zahlElement")
        {
            var group = new List<BlockListItem>();
            while (idx < blocks.Count && blocks[idx].Content.ContentType.Alias == "zahlElement")
            {
                group.Add(blocks[idx]);
                idx++;
            }
            <div class="zahl-row">
                @foreach (var g in group)
                {
                    @await Html.PartialAsync("~/Views/Partials/Blocks/zahlElement.cshtml", g)
                }
            </div>
        }
        else if (alias == "dateiElement")
        {
            var group = new List<BlockListItem>();
            while (idx < blocks.Count && blocks[idx].Content.ContentType.Alias == "dateiElement")
            {
                group.Add(blocks[idx]);
                idx++;
            }
            <div class="datei-row">
                @foreach (var g in group)
                {
                    @await Html.PartialAsync("~/Views/Partials/Blocks/dateiElement.cshtml", g)
                }
            </div>
        }
        else
        {
            @await Html.PartialAsync($"~/Views/Partials/Blocks/{alias}.cshtml", block)
            idx++;
        }
    }
}
</main>
@section Scripts {
    @if (hasRes)
    {
        <script src="/js/reservierung.js"></script>
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
    }
}
