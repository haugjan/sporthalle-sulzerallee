@namespace SporthalleWeb.Features.Booking.Admin
<style>
    .reservierung-admin { height: 100%; display: flex; flex-direction: column; }

    .admin-subnav {
        background: #1e4d82;
        display: flex;
        align-items: stretch;
        padding: 0 0.5rem;
        flex-shrink: 0;
    }
    .subnav-btn {
        color: rgba(255, 255, 255, 0.75);
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.7rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: color 0.15s ease, background 0.15s ease;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .subnav-btn:hover { color: #fff; background: rgba(255,255,255,0.1); }
    .subnav-btn.active { color: #fff; border-bottom-color: #5dade2; }

    .admin-content { padding: 1.5rem; flex: 1; overflow-y: auto; }

    /* Edit-Dialog Tageskalender */
    .ec-slot-selected { background: rgba(37, 99, 235, 0.15); }
    .ec-slot-conflict  { background: rgba(220, 38, 38, 0.2); cursor: not-allowed !important; }
    .ec-slot-booked    { background: rgba(100, 100, 100, 0.12); cursor: not-allowed !important; }
    .ec-drag           { background: rgba(37, 99, 235, 0.3) !important; }
</style>

<div class="reservierung-admin">

    <nav class="admin-subnav">
        @foreach (var tab in _tabs)
        {
            <button class="subnav-btn @(_activeTab == tab ? "active" : "")"
                    @onclick="() => SetTab(tab)">
                @tab
                @if (tab == "Anfragen" && _pendingCount > 0)
                {
                    <span class="badge bg-danger">@_pendingCount</span>
                }
            </button>
        }
    </nav>

    <div class="admin-content">
        @switch (_activeTab)
        {
            case "Anfragen":
                <AdminRequestsComponent AdminUser="@AdminUser"
                                        OnPendingCountChanged="c => _pendingCount = c" />
                break;
            case "Buchungen":
                <AdminBookingsComponent AdminUser="@AdminUser" />
                break;
            case "Blocker":
                <AdminBlockerComponent AdminUser="@AdminUser" />
                break;
            case "Serie":
                <AdminRecurringComponent AdminUser="@AdminUser" />
                break;
            case "Erfassen":
                <AdminCreateComponent AdminUser="@AdminUser" />
                break;
            case "Konfiguration":
                <AdminConfigurationComponent />
                break;
        }
    </div>

</div>

@code {
    [Parameter] public string AdminUser { get; set; } = "admin";

    private static readonly string[] _tabs = ["Anfragen", "Buchungen", "Blocker", "Serie", "Erfassen", "Konfiguration"];
    private string _activeTab = "Anfragen";
    private int _pendingCount;

    private void SetTab(string tab) => _activeTab = tab;
}
